---
import Base from '../layouts/Base.astro';
import Fact from '../components/Fact.astro';
import Picture from '../components/Picture.astro';
import Carousel from '../components/Carousel.astro';
import { site, dvet } from '../config/site';
import { getCollection } from 'astro:content';

const courses = (await getCollection('courses')).sort((a, b) => a.data.order - b.data.order);

/** Rotating campus carousel on the home page. */
const facilitySlides = [
  { src: 'gallery-electrical-1', cap: 'Electrical machines lab' },
  { src: 'gallery-computer-1', cap: 'Computer lab for the COPA course' },
  { src: 'gallery-auditorium-1', cap: 'Auditorium' },
  { src: 'gallery-solar-1', cap: 'Solar technician lab' },
  { src: 'gallery-hall', cap: 'Seminar hall' },
  { src: 'gallery-workshop-hall', cap: 'Main workshop hall' },
];

/** A few highlights on the home page; the full list is on /facilities. */
const facilityHighlights = [
  'Well-equipped workshops', 'Computer lab', 'Library', 'Auditorium',
  'Amphitheatre', 'CCTV & security', 'Ramp access',
];

const schema = [
  {
    '@type': 'ItemList',
    itemListElement: courses.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Course',
        name: `${c.data.name} — ITI Course`,
        description: c.data.summary,
        url: new URL(`/courses/${c.id}`, Astro.site).href,
        provider: { '@type': 'EducationalOrganization', name: site.name, sameAs: Astro.site?.href },
      },
    })),
  },
];

const fmt = (d: string) =>
  new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
---

<Base
  title={`${site.name}, Akola — ${site.approval} ITI | Admissions ${site.admission.year} Open`}
  description={`${site.approval} ITI in Babhulgaon, Akola. Courses after 10th: Electrician, COPA, Solar Technician. Welder after 8th. Run by ${site.runBy}. Call ${site.phonePrimary}.`}
  schema={schema}
>
  <!-- Admissions band. Gold reads as a seal; the traffic-light green it replaced
       read as a chat notification. -->
  <div class="border-b border-gold-300 bg-gold-100">
    <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-x-2 gap-y-1 px-4 py-2.5 text-center">
      <span class="kicker text-gold-800">Admissions {site.admission.year}</span>
      <span class="text-sm text-stone-800">
        <Fact value={site.admission.statusLine} fallback="Institute-level seats are open now." />
      </span>
      <a href="/admissions" class="text-sm font-semibold text-navy-700 underline underline-offset-2">
        How to apply
      </a>
    </div>
  </div>

  <!--
    HERO — a proper banner: the real campus fills it, a navy gradient rises from
    the bottom so the headline stays readable while the building is still visible
    (a bottom gradient, not a flat dim of the whole image).
  -->
  <section class="relative isolate bg-navy-900">
    <Picture
      src="campus-entrance"
      alt="Dekson ITI campus at Babhulgaon, Near College of Engineering and Technology, Akola"
      priority={true}
      sizes="100vw"
      class="absolute inset-0 -z-10 h-full w-full object-cover object-center"
      width={1600}
      height={900}
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-navy-900 via-navy-900/70 to-navy-900/25"></div>

    <div class="mx-auto flex min-h-[440px] max-w-6xl flex-col justify-end px-4 py-12 md:min-h-[560px] md:py-16">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold tracking-[0.14em] text-gold-300 uppercase">
          Babhulgaon · Akola · {site.approval}
        </p>
        <h1 class="mt-3 font-serif text-4xl leading-[1.08] font-bold text-white sm:text-5xl md:text-6xl">
          Learn a skill.<br />Earn a living.
        </h1>
        <p class="mt-4 max-w-xl leading-relaxed text-clay-100">
          A government-recognised Industrial Training Institute run by {site.runBy} — practical
          training, a certificate valid across India, and a real trade in your hands.
        </p>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <a href={`tel:${site.phonePrimary}`} class="inline-flex items-center justify-center bg-gold-500 px-6 py-3.5 font-semibold text-navy-900 transition hover:brightness-105">
            Call <span class="tnum notranslate ml-1.5" translate="no">{site.phonePrimary}</span>
          </a>
          <a href={`https://wa.me/91${site.whatsapp}`} rel="noopener" class="inline-flex items-center justify-center bg-white/10 px-6 py-3.5 font-semibold text-white ring-1 ring-white/40 backdrop-blur-sm transition hover:bg-white/20">
            Message on WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Eligibility bar — clean facts strip directly under the banner. -->
  <div class="border-b border-stone-200 bg-clay-50">
    <div class="mx-auto grid max-w-6xl gap-x-8 gap-y-2 px-4 py-4 sm:grid-cols-2">
      <div class="flex gap-4 sm:border-r sm:border-stone-200">
        <span class="w-24 shrink-0 text-xs font-semibold tracking-wide text-stone-500 uppercase">After 10th</span>
        <span class="text-sm font-medium text-stone-800">Electrician · COPA · Solar Technician</span>
      </div>
      <div class="flex gap-4 sm:pl-4">
        <span class="w-24 shrink-0 text-xs font-semibold tracking-wide text-stone-500 uppercase">After 8th</span>
        <span class="text-sm font-medium text-stone-800">
          Welder
          <span class="ml-1 bg-gold-100 px-1.5 py-0.5 text-xs font-semibold text-gold-800">no 10th needed</span>
        </span>
      </div>
    </div>
  </div>

  <!--
    Accreditation strip — the single most important trust device on an Indian
    ITI site, near the fold. Official Skill India + ITI marks; DGT/NCVT and DVET
    as text seals. Full colour on white, equal height, generously spaced.
  -->
  <section aria-label="Recognitions & Affiliations" class="border-b border-stone-200 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-8">
      <p class="kicker text-center text-stone-400">Recognised &amp; affiliated by</p>
      <div class="mt-5 flex flex-wrap items-center justify-center gap-x-10 gap-y-6">
        <img src="/images/accred-skillindia.png" alt="Skill India" width="146" height="120" class="h-14 w-auto object-contain" loading="lazy" />
        <img src="/images/accred-iti.png" alt="Industrial Training Institute (ITI)" width="180" height="120" class="h-14 w-auto object-contain" loading="lazy" />
        <span class="border-l border-stone-200 pl-8 text-center">
          <span class="block font-serif text-base font-bold text-navy-800">DGT / NCVT</span>
          <span class="block text-xs text-stone-500">New Delhi</span>
        </span>
        <span class="text-center">
          <span class="block font-serif text-base font-bold text-navy-800">DVET</span>
          <span class="block text-xs text-stone-500">Maharashtra State</span>
        </span>
      </div>
    </div>
  </section>

  <!-- Credential plaque + notice ledger.
       The institute code is the most important datum on the site; it gets the
       serif display face, not font-mono (monospace-as-decoration is a dev tell). -->
  <section class="bg-stone-50">
    <div class="mx-auto grid max-w-6xl gap-px bg-stone-200 lg:grid-cols-5">
      <div class="bg-stone-50 p-8 lg:col-span-2">
        <p class="kicker">Our Institute Code</p>
        <div class="mt-3 border-2 border-navy-700 bg-white px-5 py-6 text-center">
          <p class="notranslate font-serif text-3xl font-bold break-all text-navy-700 tnum" translate="no">
            <Fact value={site.instituteCode} />
          </p>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-stone-600">
          Enter this code in your option form at
          <a href={dvet.portal} rel="noopener" class="font-semibold text-navy-700 underline">admission.dvet.gov.in</a>
          to choose {site.name}.
        </p>
      </div>

      <!-- A notice board should look like a notice board: a ledger of dated
           rows. Not a rounded card with a drop shadow. -->
      <div class="bg-white p-8 lg:col-span-3">
        <div class="flex items-baseline justify-between border-b-2 border-navy-700 pb-2">
          <p class="kicker">Latest Notices</p>
          <span class="text-xs text-stone-400">Updated {fmt(site.notices[0].date)}</span>
        </div>
        <ul>
          {site.notices.map((n) => (
            <li class="border-b border-stone-200">
              <a href={n.href} class="group flex flex-col gap-1 py-3 sm:flex-row sm:items-baseline sm:gap-5">
                <time datetime={n.date} class="tnum notranslate w-24 shrink-0 text-xs font-semibold text-stone-400" translate="no">
                  {fmt(n.date)}
                </time>
                <span class="text-sm leading-relaxed text-stone-700 group-hover:text-navy-700 group-hover:underline">
                  {n.text}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- COURSES -->
  <section class="mx-auto max-w-6xl px-4 py-20">
    <div class="grid gap-6 lg:grid-cols-12">
      <div class="hangs lg:col-span-8">
        <p class="kicker">What you can study</p>
        <h2 class="mt-2 font-serif text-3xl font-bold text-stone-900 md:text-4xl">Our Courses</h2>
        <p class="mt-3 max-w-xl leading-relaxed text-stone-600">
          Four government-recognised courses. Each one teaches a practical trade and ends in a
          certificate recognised across India.
        </p>
      </div>
      <div class="flex items-end lg:col-span-4 lg:justify-end">
        <a href="/courses" class="text-sm font-semibold text-navy-700 hover:underline">
          All courses &rarr;
        </a>
      </div>
    </div>

    <div class="mt-10 grid gap-px border border-stone-200 bg-stone-200 sm:grid-cols-2 lg:grid-cols-4">
      {courses.map((c) => (
        <a href={`/courses/${c.id}`} class="group flex flex-col bg-white transition-colors hover:bg-clay-50">
          {c.data.image && (
            <div class="relative aspect-[4/3] overflow-hidden bg-stone-100">
              <Picture src={c.data.image} alt={`${c.data.name} workshop at Dekson ITI`} widths={[640, 1024]} sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 25vw" class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" width={1024} height={768} />
            </div>
          )}
          <div class="flex flex-1 flex-col p-6">
            <h3 class="font-serif text-xl leading-snug font-bold text-stone-900 group-hover:text-navy-700">
              Become a{/^[aeiouAEIOU]/.test(c.data.shortName) ? "n" : ""} {c.data.shortName}
            </h3>
            <p class="mr mt-1 text-xs text-stone-500">{c.data.nameMr}</p>
            <p class="mt-3 text-sm leading-relaxed text-stone-600">{c.data.summary}</p>

            <div class="mt-5 border-t border-stone-200 pt-3">
              <span class="text-xs font-semibold tracking-wide text-stone-500 uppercase">Eligibility</span>
              <p class="mt-0.5 text-sm font-semibold text-stone-800">{c.data.eligibility}</p>
            </div>
            {c.data.highlight && (
              <p class="mt-3 bg-gold-100 px-2 py-1 text-xs font-semibold text-gold-800">{c.data.highlight}</p>
            )}
          </div>
        </a>
      ))}
    </div>

    <p class="mt-4 text-xs text-stone-400">
      Photographs are of the workshops and labs at Dekson ITI, Babhulgaon.
      <a href="/gallery" class="underline hover:text-navy-700">See the full gallery</a>.
    </p>
  </section>

  <!-- WHY DEKSON — three refined proof points on a light ground. Each card has a
       coloured top rule, a serif heading and a link. Airy and professional. -->
  <section class="border-y border-stone-200 bg-stone-50 py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="mx-auto max-w-2xl text-center">
        <p class="kicker">Why Dekson</p>
        <h2 class="mt-2 font-serif text-3xl font-bold text-stone-900 md:text-4xl">
          A place you can trust with your future
        </h2>
        <p class="mt-3 leading-relaxed text-stone-600">
          Three simple reasons — each of them something you can check for yourself.
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        <div class="border-t-4 border-verified-700 bg-white p-7 shadow-sm">
          <p class="text-xs font-semibold tracking-[0.12em] text-verified-700 uppercase">Government recognised</p>
          <h3 class="mt-3 font-serif text-xl font-bold text-stone-900">{site.approval}</h3>
          <p class="mt-2 leading-relaxed text-stone-600">
            Your certificate is valid across India. You can verify our approval yourself on the NCVT
            MIS portal before you pay a single rupee.
          </p>
          <a href="/admissions" class="mt-4 inline-block text-sm font-semibold text-navy-700 hover:underline">How to apply &rarr;</a>
        </div>

        <div class="border-t-4 border-navy-700 bg-white p-7 shadow-sm">
          <p class="text-xs font-semibold tracking-[0.12em] text-navy-700 uppercase">Ready campus</p>
          <h3 class="mt-3 font-serif text-xl font-bold text-stone-900">Built and in use now</h3>
          <p class="mt-2 leading-relaxed text-stone-600">
            Well-equipped workshops, a computer lab, library and auditorium — newly built. Walk
            through it before you decide; the offer is open to anyone.
          </p>
          <a href="/facilities" class="mt-4 inline-block text-sm font-semibold text-navy-700 hover:underline">See our facilities &rarr;</a>
        </div>

        <div class="border-t-4 border-gold-500 bg-white p-7 shadow-sm">
          <p class="text-xs font-semibold tracking-[0.12em] text-gold-700 uppercase">Trusted roots</p>
          <h3 class="mt-3 font-serif text-xl font-bold text-stone-900">Backed since 1967</h3>
          <p class="mt-2 leading-relaxed text-stone-600">
            Established by {site.runBy}, which has served Akola for over five decades and already runs
            two schools and a college in the district.
          </p>
          <a href="/about" class="mt-4 inline-block text-sm font-semibold text-navy-700 hover:underline">About the institute &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FACILITIES — a rotating campus carousel + a few highlights. The complete
       list lives on the Facilities page to keep the home page uncluttered. -->
  <section class="mx-auto max-w-6xl px-4 py-16 md:py-20">
    <div class="grid gap-6 lg:grid-cols-12">
      <div class="hangs lg:col-span-8">
        <p class="kicker">On campus</p>
        <h2 class="mt-2 font-serif text-3xl font-bold text-stone-900 md:text-4xl">A campus built and ready</h2>
        <p class="mt-3 max-w-xl leading-relaxed text-stone-600">
          Well-equipped workshops, a computer lab, library, auditorium and more — newly built and
          in use now.
        </p>
      </div>
      <div class="flex items-end lg:col-span-4 lg:justify-end">
        <a href="/facilities" class="text-sm font-semibold text-navy-700 hover:underline">See all facilities &rarr;</a>
      </div>
    </div>

    <Carousel class="mt-8" slides={facilitySlides} ratio="aspect-[16/9] sm:aspect-[2/1]" />

    <ul class="mt-6 flex flex-wrap gap-2">
      {facilityHighlights.map((f) => (
        <li class="border border-stone-200 bg-white px-3 py-1.5 text-sm text-stone-700">{f}</li>
      ))}
      <li>
        <a href="/facilities" class="inline-block bg-navy-50 px-3 py-1.5 text-sm font-semibold text-navy-700 hover:bg-navy-100">
          + more &rarr;
        </a>
      </li>
    </ul>
  </section>

  <!-- Final CTA — compact and quiet. A closing prompt, not a second hero. -->
  <section class="border-t border-stone-200 bg-stone-50">
    <div class="mx-auto flex max-w-5xl flex-col items-center gap-5 px-4 py-10 text-center sm:flex-row sm:justify-between sm:text-left">
      <div>
        <h2 class="font-serif text-xl font-bold text-stone-900">Have a question about admission?</h2>
        <p class="mt-1 text-sm text-stone-600">
          Call us and we will guide you, step by step, in Marathi — or
          <a href="/contact" class="font-semibold text-navy-700 underline">visit the campus</a>.
        </p>
      </div>
      <div class="flex shrink-0 flex-col gap-2 sm:flex-row">
        <a href={`tel:${site.phonePrimary}`} class="inline-flex items-center justify-center bg-navy-700 px-5 py-3 text-sm font-semibold text-white hover:bg-navy-800">
          Call <span class="tnum notranslate ml-1.5" translate="no">{site.phonePrimary}</span>
        </a>
        <a href={`https://wa.me/91${site.whatsapp}`} rel="noopener" class="inline-flex items-center justify-center bg-whatsapp px-5 py-3 text-sm font-semibold text-white hover:brightness-110">
          WhatsApp
        </a>
      </div>
    </div>
  </section>
</Base>

---
import Base from '../../layouts/Base.astro';
import { site } from '../../config/site';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides')).sort((a, b) => a.data.order - b.data.order);

const schema = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
      { '@type': 'ListItem', position: 2, name: 'Guides', item: new URL('/guides', Astro.site).href },
    ],
  },
];
---

<Base
  title={`ITI Admission Guides — Akola | ${site.name}`}
  description="Simple guides for ITI admission in Akola: how to apply on the DVET portal, which course to choose, and your options after 10th."
  schema={schema}
>
  <div class="mx-auto max-w-4xl px-4 py-12 md:py-16">
    <nav aria-label="Breadcrumb" class="text-sm text-stone-500">
      <a href="/" class="hover:text-navy-700 hover:underline">Home</a>
      <span class="mx-2 text-stone-300">/</span><span class="text-stone-700">Guides</span>
    </nav>

    <div class="hangs mt-8">
      <p class="kicker">Helpful reading</p>
      <h1 class="mt-2 font-serif text-4xl font-bold text-stone-900 md:text-5xl">Admission Guides</h1>
      <p class="mt-3 max-w-2xl text-lg leading-relaxed text-stone-700">
        Straight answers to the questions students and parents ask about ITI admission in Akola.
      </p>
    </div>

    <div class="mt-10 grid gap-px border border-stone-200 bg-stone-200">
      {guides.map((g) => (
        <a href={`/guides/${g.id}`} class="group bg-white p-6 transition-colors hover:bg-clay-50">
          <h2 class="font-serif text-xl font-bold text-stone-900 group-hover:text-navy-700">{g.data.title}</h2>
          <p class="mt-2 leading-relaxed text-stone-600">{g.data.description}</p>
          <span class="mt-3 inline-block text-sm font-semibold text-navy-700">Read the guide &rarr;</span>
        </a>
      ))}
    </div>
  </div>
</Base>

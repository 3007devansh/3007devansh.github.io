---
import Base from '../../layouts/Base.astro';
import { site } from '../../config/site';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((g) => ({ params: { id: g.id }, props: { guide: g } }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const d = guide.data;
const url = new URL(`/guides/${guide.id}`, Astro.site).href;

const schema = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
      { '@type': 'ListItem', position: 2, name: 'Guides', item: new URL('/guides', Astro.site).href },
      { '@type': 'ListItem', position: 3, name: d.title, item: url },
    ],
  },
  {
    '@type': 'Article',
    headline: d.title,
    description: d.description,
    datePublished: d.published,
    dateModified: d.updated ?? d.published,
    author: { '@type': 'Organization', name: site.nameFull },
    publisher: { '@id': `${Astro.site?.origin}/#organization` },
    mainEntityOfPage: url,
    inLanguage: 'en-IN',
  },
];
---

<Base title={`${d.title} | ${site.name}`} description={d.description} schema={schema}>
  <article class="mx-auto max-w-3xl px-4 py-12">
    <nav aria-label="Breadcrumb" class="text-sm text-stone-500">
      <a href="/" class="hover:text-navy-700 hover:underline">Home</a>
      <span class="mx-2 text-stone-300">/</span>
      <a href="/guides" class="hover:text-navy-700 hover:underline">Guides</a>
    </nav>

    <h1 class="mt-6 font-serif text-3xl leading-tight font-bold text-stone-900 md:text-4xl">{d.title}</h1>

    <div class="prose prose-stone mt-8 max-w-none prose-headings:font-serif prose-headings:text-stone-900 prose-a:text-navy-700 prose-strong:text-stone-900">
      <Content />
    </div>

    <!-- Conversion block -->
    <div class="mt-12 border-2 border-navy-700 p-6 text-center">
      <h2 class="font-serif text-xl font-bold text-stone-900">Admissions 2026-27 are open</h2>
      <p class="mt-2 text-sm text-stone-600">
        Institute Code <strong class="notranslate tnum text-navy-700" translate="no">{site.instituteCode}</strong>
        · Call us and we will guide you, step by step, in Marathi.
      </p>
      <div class="mt-5 flex flex-col justify-center gap-3 sm:flex-row">
        <a href={`tel:${site.phonePrimary}`} class="bg-navy-700 px-6 py-3 font-semibold text-white hover:bg-navy-800">
          Call <span class="tnum notranslate ml-1" translate="no">{site.phonePrimary}</span>
        </a>
        <a href={`https://wa.me/91${site.whatsapp}`} rel="noopener" class="bg-whatsapp px-6 py-3 font-semibold text-white hover:brightness-110">
          WhatsApp us
        </a>
        <a href="/admissions" class="border-2 border-stone-300 px-6 py-3 font-semibold text-stone-800 hover:border-navy-700 hover:text-navy-700">
          How to apply
        </a>
      </div>
    </div>
  </article>
</Base>

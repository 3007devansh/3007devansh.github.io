---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
---

<Base title={`Page not found | ${site.name}`} description="The page you were looking for could not be found.">
  <div class="mx-auto max-w-2xl px-4 py-20 text-center">
    <p class="font-serif text-6xl font-bold text-navy-700">404</p>
    <h1 class="mt-4 font-serif text-3xl font-bold text-stone-900">Page not found</h1>
    <p class="mt-3 leading-relaxed text-stone-600">
      The page you were looking for doesn't exist or has moved. Here's where to go instead:
    </p>
    <div class="mt-8 grid gap-px border border-stone-200 bg-stone-200 sm:grid-cols-2">
      {[
        { href: '/', label: 'Home' },
        { href: '/courses', label: 'Our Courses' },
        { href: '/admissions', label: 'Admissions 2026-27' },
        { href: '/contact', label: 'Contact & Directions' },
      ].map((l) => (
        <a href={l.href} class="bg-white p-4 font-semibold text-navy-700 hover:bg-clay-50">{l.label}</a>
      ))}
    </div>
    <a href={`tel:${site.phonePrimary}`} class="mt-8 inline-flex items-center justify-center bg-navy-700 px-6 py-3 font-semibold text-white hover:bg-navy-800">
      Call <span class="tnum notranslate ml-1.5" translate="no">{site.phonePrimary}</span>
    </a>
  </div>
</Base>

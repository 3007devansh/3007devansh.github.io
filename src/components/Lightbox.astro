---
/**
 * Click-to-enlarge lightbox. Include once (in Base). Any <img data-zoom> on the
 * page opens here on click. Vanilla JS, no dependencies.
 *
 * Accessibility: role=dialog, Esc to close, click backdrop to close, focus moves
 * to the close button and returns to the trigger on close.
 */
---

<div
  id="lightbox"
  class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/90 p-4"
  role="dialog"
  aria-modal="true"
  aria-label="Enlarged image"
>
  <button
    id="lightbox-close"
    type="button"
    class="absolute top-3 right-3 flex h-11 w-11 items-center justify-center text-3xl leading-none text-white/80 hover:text-white"
    aria-label="Close"
  >×</button>
  <figure class="m-0 flex max-h-full max-w-5xl flex-col items-center">
    <img id="lightbox-img" src="" alt="" class="max-h-[82vh] w-auto max-w-full object-contain" />
    <figcaption id="lightbox-cap" class="mt-3 text-center text-sm text-white/70"></figcaption>
  </figure>
</div>

<script>
  (function () {
    const box = document.getElementById('lightbox');
    const img = document.getElementById('lightbox-img') as HTMLImageElement | null;
    const cap = document.getElementById('lightbox-cap');
    const closeBtn = document.getElementById('lightbox-close');
    if (!box || !img || !cap || !closeBtn) return;
    let lastFocus: HTMLElement | null = null;

    const open = (full: string, alt: string) => {
      img.src = full;
      img.alt = alt;
      cap.textContent = alt;
      box.classList.remove('hidden');
      box.classList.add('flex');
      document.body.style.overflow = 'hidden';
      (closeBtn as HTMLElement).focus();
    };
    const close = () => {
      box.classList.add('hidden');
      box.classList.remove('flex');
      img.src = '';
      document.body.style.overflow = '';
      lastFocus?.focus();
    };

    // Delegate clicks from any zoomable image on the page.
    document.addEventListener('click', (e) => {
      const t = (e.target as HTMLElement)?.closest('[data-zoom]') as HTMLImageElement | null;
      if (!t) return;
      lastFocus = t;
      open(t.dataset.full || t.currentSrc || t.src, t.alt || '');
    });

    // Make zoomable images look and behave interactive.
    document.querySelectorAll<HTMLElement>('[data-zoom]').forEach((el) => {
      el.style.cursor = 'zoom-in';
      el.setAttribute('role', 'button');
      el.setAttribute('tabindex', '0');
      el.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
          e.preventDefault();
          lastFocus = el;
          const im = el as HTMLImageElement;
          open(im.dataset.full || im.currentSrc || im.src, im.alt || '');
        }
      });
    });

    closeBtn.addEventListener('click', close);
    box.addEventListener('click', (e) => { if (e.target === box) close(); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !box.classList.contains('hidden')) close();
    });
  })();
</script>

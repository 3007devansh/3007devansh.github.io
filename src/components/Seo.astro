---
/**
 * All SEO for a page: meta, Open Graph, canonical, hreflang, JSON-LD.
 *
 * Schema strategy:
 *  - Every page carries EducationalOrganization + LocalBusiness (sitewide identity).
 *  - Course pages add Course + breadcrumbs.
 *  - The FAQ page adds FAQPage.
 * LocalBusiness matters most here: "ITI near me" is a map query, and the
 * Google Business Profile plus consistent NAP is what wins it — not the site copy.
 */
import { site, isTodo } from '../config/site';

interface Props {
  title: string;
  description: string;
  /** Optional extra JSON-LD graph nodes for this page. */
  schema?: Record<string, unknown>[];
  ogImage?: string;
  noindex?: boolean;
}
const { title, description, schema = [], ogImage = '/images/campus-entrance.jpg', noindex = false } = Astro.props;

const origin = Astro.site?.origin ?? 'https://example.invalid';
const canonical = new URL(Astro.url.pathname, origin).href;
const ogImageAbs = new URL(ogImage, origin).href;

const orgId = `${origin}/#organization`;

const address = {
  '@type': 'PostalAddress',
  streetAddress: 'Babhulgaon, Near College of Engineering and Technology',
  addressLocality: 'Akola',
  addressRegion: 'Maharashtra',
  postalCode: site.pincode,
  addressCountry: 'IN',
};

const organization = {
  '@type': ['EducationalOrganization', 'LocalBusiness'],
  '@id': orgId,
  name: site.nameFull,
  alternateName: [
    'Dekson ITI',
    'Deksons ITI',
    'Deksons ITI Akola',
    'Deksons Institute Akola',
    'Dekson ITI Akola',
    site.nameMr,
  ],
  description: `${site.approval} Industrial Training Institute in Babhulgaon, Akola, offering Electrician, Welder, COPA and Solar Technician courses. Run by ${site.runBy}. Institute Code ${site.instituteCode}.`,
  url: origin,
  logo: new URL('/images/logo-deksons-512.png', origin).href,
  image: ogImageAbs,
  telephone: `+91${site.phonePrimary}`,
  email: site.email,
  address,
  /**
   * Village-level coordinates for Babhulgaon, Akola (OpenStreetMap). Good enough
   * for "near me" intent. Replace with the exact campus pin from the Google
   * Business Profile once it is approved.
   */
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 20.7040,
    longitude: 77.0846,
  },
  // Regional reach — helps "ITI near <town>" across Akola district & neighbours.
  areaServed: [
    { '@type': 'City', name: 'Akola' },
    { '@type': 'AdministrativeArea', name: 'Akola District' },
    ...['Akot', 'Balapur', 'Murtizapur', 'Telhara', 'Patur', 'Barshitakli', 'Hivarkhed'].map(
      (n) => ({ '@type': 'City', name: n }),
    ),
    { '@type': 'AdministrativeArea', name: 'Vidarbha' },
  ],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      opens: '10:00',
      closes: '17:00',
    },
  ],
  founder: { '@type': 'Organization', name: site.runBy },
  ...(isTodo(site.email) ? {} : { email: site.email }),
  ...(isTodo(site.mapsUrl) ? {} : { hasMap: site.mapsUrl }),
};

const graph = [organization, ...schema];
const jsonld = { '@context': 'https://schema.org', '@graph': graph };
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex,nofollow" />}

<meta property="og:type" content="website" />
<meta property="og:site_name" content={site.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageAbs} />
<meta property="og:locale" content="en_IN" />
<meta name="twitter:card" content="summary_large_image" />

<meta name="geo.region" content="IN-MH" />
<meta name="geo.placename" content="Akola" />

<script type="application/ld+json" set:html={JSON.stringify(jsonld)} is:inline />

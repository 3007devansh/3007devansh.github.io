---
import Base from '../layouts/Base.astro';
import Fact from '../components/Fact.astro';
import { site, dvet } from '../config/site';

/** DVET CAP steps, verified against Mahiti Pustika Bhag-2, ITI Admission 2026. */
const steps = [
  {
    t: 'Register on the DVET portal',
    d: 'Go to admission.dvet.gov.in, create an account, fill the admission form and pay the application fee.',
  },
  {
    t: 'Get your merit number',
    d: 'After the merit list is prepared, log in to check your State, Category and Home District merit numbers. You also receive them by SMS.',
  },
  {
    t: 'Fill your option form',
    d: 'Choose your preferred institutes and courses. To select us, enter our Institute Code.',
  },
  {
    t: 'Receive your allotment letter',
    d: 'If a seat is allotted to you, you get an SMS. Log in and download the Allotment Letter. You can also collect it from any nearby ITI.',
  },
  {
    t: 'Report to the institute',
    d: `Bring the printed allotment letter and your documents to ${site.name}, Babhulgaon, within the dates given.`,
  },
  {
    t: 'Confirm your admission',
    d: 'We check your documents, collect the fee, and hand you your Admission Confirmation Slip.',
  },
];
---

<Base
  title={`Admissions ${site.admission.year} — Open Now | ${site.name}, Akola`}
  description={`Admissions are open at ${site.name}, Akola. CAP Round 2 and Management Quota seats available. Institute Code ${site.instituteCode}. Call ${site.phonePrimary} or visit the campus.`}
>
  <div class="bg-maroon-700 px-4 py-3 text-center text-sm font-semibold text-white">
    <Fact value={site.admission.statusLine} fallback="Admissions are open now." />
  </div>

  <div class="mx-auto max-w-4xl px-4 py-12">
    <div class="hangs">
      <p class="kicker">Admissions {site.admission.year}</p>
      <h1 class="mt-2 font-serif text-4xl font-bold text-stone-900 md:text-5xl">Admissions are open</h1>
      <p class="mt-3 max-w-2xl text-lg leading-relaxed text-stone-700">
        There is still time to join {site.name} this year. Seats are available now. The simplest first
        step is to <strong class="text-stone-900">call us or visit the campus</strong> — we will look at
        your marks, explain your options, and take you through the whole process.
      </p>
    </div>

    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <a href={`tel:${site.phonePrimary}`} class="inline-flex items-center justify-center bg-maroon-700 px-6 py-3.5 font-semibold text-white hover:bg-maroon-800">
        Call <span class="tnum notranslate ml-1.5" translate="no">{site.phonePrimary}</span>
      </a>
      <a href={`https://wa.me/91${site.whatsapp}`} rel="noopener" class="inline-flex items-center justify-center border-2 border-stone-300 px-6 py-3.5 font-semibold text-stone-800 hover:border-maroon-700 hover:text-maroon-700">
        Message on WhatsApp
      </a>
    </div>

    <!-- Two honest routes to a seat. Leads with the human one. -->
    <h2 class="mt-16 font-serif text-2xl font-bold text-stone-900">Two ways to secure your seat</h2>
    <div class="mt-6 grid gap-px border border-stone-200 bg-stone-200 md:grid-cols-2">
      <div class="bg-white p-6">
        <p class="kicker">Easiest</p>
        <h3 class="mt-2 font-serif text-xl font-bold text-stone-900">Visit us or call</h3>
        <p class="mt-3 leading-relaxed text-stone-600">
          Come to the campus, or call
          <a href={`tel:${site.phonePrimary}`} class="font-semibold text-maroon-700 underline">{site.phonePrimary}</a>.
          We will tell you which courses have seats, help you with the Management Quota, and guide you
          through the online steps if you need them. This is the quickest way to understand where you stand.
        </p>
        <a href="/contact" class="mt-4 inline-block text-sm font-semibold text-maroon-700 hover:underline">Campus address &amp; hours &rarr;</a>
      </div>
      <div class="bg-white p-6">
        <p class="kicker">Online</p>
        <h3 class="mt-2 font-serif text-xl font-bold text-stone-900">Through the DVET portal</h3>
        <p class="mt-3 leading-relaxed text-stone-600">
          Register at admission.dvet.gov.in, fill your option form, and enter our Institute Code to
          choose {site.name}. The steps are below. Call us anytime and we will walk you through it.
        </p>
        <a href={dvet.portal} rel="noopener" class="mt-4 inline-block text-sm font-semibold text-maroon-700 hover:underline">Open the DVET portal &rarr;</a>
      </div>
    </div>

    <!-- Institute code: serif display, not font-mono. -->
    <div class="mt-10 border-2 border-maroon-700 bg-maroon-50 p-6 text-center">
      <p class="kicker">Enter this code in your option form</p>
      <p class="notranslate tnum mt-3 font-serif text-4xl font-bold break-all text-maroon-700" translate="no">
        <Fact value={site.instituteCode} />
      </p>
      <p class="mt-2 text-sm text-stone-600">Institute Code · {site.nameFull}</p>
    </div>

    <!-- Steps -->
    <h2 class="mt-16 font-serif text-2xl font-bold text-stone-900">Applying online — step by step</h2>
    <ol class="mt-6 space-y-5">
      {steps.map((s, i) => (
        <li class="flex gap-4">
          <span class="tnum flex h-9 w-9 shrink-0 items-center justify-center bg-maroon-700 font-bold text-white">
            {i + 1}
          </span>
          <div>
            <h3 class="font-bold text-stone-900">{s.t}</h3>
            <p class="mt-1 leading-relaxed text-stone-600">{s.d}</p>
          </div>
        </li>
      ))}
    </ol>

    <!-- Documents -->
    <h2 class="mt-16 font-serif text-2xl font-bold text-stone-900">Documents to bring</h2>
    <ul class="mt-5 grid gap-px border border-stone-200 bg-stone-200 sm:grid-cols-2">
      {dvet.documentsAtAdmission.map((d) => (
        <li class="flex items-start gap-3 bg-white p-4 text-stone-700">
          <span class="mt-1.5 h-1.5 w-1.5 shrink-0 bg-maroon-700" aria-hidden="true"></span>{d}
        </li>
      ))}
    </ul>
    <div class="mt-5 space-y-3 border-l-4 border-gold-700 bg-gold-50 p-4 text-sm text-stone-700">
      <p>{dvet.documentsRetained}</p>
      <p>
        If your documents are not ready at confirmation, the institute allows
        <strong>{dvet.documentGraceDays} days</strong> to submit them.
      </p>
    </div>

    <!-- Fees -->
    <h2 class="mt-16 font-serif text-2xl font-bold text-stone-900">Fees</h2>
    <p class="mt-3 leading-relaxed text-stone-700">
      Fees are charged <strong class="text-stone-900">as per Government norms</strong>. {dvet.instalmentsAllowed}
      For the exact fee for your course, please
      <a href={`tel:${site.phonePrimary}`} class="font-semibold text-maroon-700 underline">call {site.phonePrimary}</a>
      or visit the campus — we will give you the full break-up.
    </p>

    <!-- Anti-fraud warning -->
    <div class="mt-12 border-l-4 border-maroon-700 bg-stone-50 p-5">
      <h3 class="font-serif text-lg font-bold text-stone-900">Beware of agents</h3>
      <p class="mt-2 text-sm leading-relaxed text-stone-600">
        {site.name} does not work through any admission agent or middleman. Nobody is authorised to
        collect money on our behalf. Pay fees only at the institute, and always take a receipt.
        If anyone asks you for money to "arrange" a seat, call us at {site.phonePrimary}.
      </p>
    </div>

    <!-- Help -->
    <div class="mt-12 bg-maroon-800 p-8 text-center">
      <p class="kicker text-gold-300">We will help you</p>
      <h3 class="mt-2 font-serif text-2xl font-bold text-white">Not sure where to start?</h3>
      <p class="mt-3 leading-relaxed text-clay-100">
        Call us and we will take you through everything — in Marathi — step by step.
      </p>
      <div class="mt-6 flex flex-col justify-center gap-3 sm:flex-row">
        <a href={`tel:${site.phonePrimary}`} class="bg-white px-6 py-3 font-semibold text-maroon-800 hover:bg-maroon-50">
          {site.phonePrimaryName} — <span class="tnum notranslate" translate="no">{site.phonePrimary}</span>
        </a>
        <a href={`tel:${site.phoneSecondary}`} class="border border-white/40 px-6 py-3 font-semibold text-white hover:bg-maroon-700">
          {site.phoneSecondaryName} — <span class="tnum notranslate" translate="no">{site.phoneSecondary}</span>
        </a>
      </div>
    </div>
  </div>
</Base>

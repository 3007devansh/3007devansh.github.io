---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
import { courseImageCredits } from '../config/credits';

/**
 * Attribution page. CC BY-SA requires crediting the author, linking the source,
 * naming the licence, and licensing derivatives alike. Our resized copies are
 * derivatives, so they carry the same licence.
 */
const entries = Object.entries(courseImageCredits);
---

<Base
  title={`Photo Credits | ${site.name}`}
  description="Attribution for photographs used on the DEKSON ITI website."
>
  <div class="mx-auto max-w-3xl px-4 py-12">
    <div class="hangs">
      <p class="kicker">Attribution</p>
      <h1 class="mt-2 font-serif text-4xl font-bold text-stone-900">Photo Credits</h1>
    </div>

    <section class="mt-10">
      <h2 class="font-serif text-2xl font-bold text-stone-900">Photographs of DEKSON ITI</h2>
      <p class="mt-3 leading-relaxed text-stone-600">
        All photographs of the campus, buildings, gate and grounds were taken at
        {site.name}, Waghulgaon, Akola. They are the property of the institute.
      </p>
    </section>

    <section class="mt-12">
      <h2 class="font-serif text-2xl font-bold text-stone-900">Course illustration photographs</h2>
      <div class="mt-4 border-l-4 border-maroon-700 bg-stone-50 p-5">
        <p class="leading-relaxed text-stone-700">
          The photographs shown alongside each course illustrate <strong>what the trade looks like</strong>.
          <strong class="text-stone-900">They are not photographs of DEKSON ITI</strong>, its workshops,
          its equipment or its students.
        </p>
        <p class="mt-3 text-sm leading-relaxed text-stone-600">
          Each is labelled as illustrative wherever it appears. We have not photographed our own
          workshops yet, and we will not use someone else's workshop and present it as ours. When our
          real workshop photographs are taken, these will be replaced.
        </p>
      </div>

      <ul class="mt-8 space-y-6">
        {entries.map(([course, c]) => (
          <li class="border-b border-stone-200 pb-6">
            <p class="font-semibold text-stone-900 capitalize">{course.replace('-', ' ')}</p>
            <p class="mt-1 text-sm text-stone-600">{c.caption}{c.place !== '—' && <> · {c.place}</>}</p>
            <p class="mt-2 text-sm text-stone-500">
              Photo by {c.author} ·{' '}
              <a href={c.licenseUrl} rel="noopener nofollow" class="underline hover:text-maroon-700">{c.license}</a>
              {' '}· <a href={c.sourceUrl} rel="noopener nofollow" class="underline hover:text-maroon-700">Source</a>
            </p>
          </li>
        ))}
      </ul>

      <p class="mt-6 text-sm leading-relaxed text-stone-500">
        Photographs licensed under CC BY-SA have been resized and adjusted for web use. Those modified
        copies are made available under the same licence.
      </p>
    </section>

    <section class="mt-12">
      <h2 class="font-serif text-2xl font-bold text-stone-900">Icons</h2>
      <p class="mt-3 text-sm leading-relaxed text-stone-600">
        Interface icons are from <a href="https://lucide.dev" rel="noopener nofollow" class="underline hover:text-maroon-700">Lucide</a>, ISC licence.
      </p>
    </section>
  </div>
</Base>

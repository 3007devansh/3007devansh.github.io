---
import Base from '../../layouts/Base.astro';
import { site } from '../../config/site';
import { getCollection } from 'astro:content';

const courses = (await getCollection('courses')).sort((a, b) => a.data.order - b.data.order);

const schema = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
      { '@type': 'ListItem', position: 2, name: 'Courses', item: new URL('/courses', Astro.site).href },
    ],
  },
  {
    '@type': 'ItemList',
    itemListElement: courses.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Course',
        name: `${c.data.name} — ITI Course`,
        description: c.data.summary,
        url: new URL(`/courses/${c.id}`, Astro.site).href,
        provider: { '@type': 'EducationalOrganization', name: site.name },
      },
    })),
  },
];
---

<Base
  title={`ITI Courses after 10th & 8th in Akola | ${site.name}`}
  description="ITI courses at DEKSON ITI Akola: Electrician, COPA, Solar Technician after 10th, and Welder after 8th pass. NCVT approved. Eligibility, careers and admission details."
  schema={schema}
>
  <div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
    <nav aria-label="Breadcrumb" class="text-sm text-slate-500">
      <a href="/" class="hover:text-maroon-700 hover:underline">Home</a>
      <span class="mx-1.5">/</span><span class="text-slate-700">Courses</span>
    </nav>

    <h1 class="mt-4 text-4xl font-black tracking-tight text-slate-900 md:text-5xl">Our Courses</h1>
    <p class="mt-2 mr text-lg text-slate-500">आमचे अभ्यासक्रम</p>
    <p class="mt-5 max-w-2xl text-lg text-slate-600">
      DEKSON ITI offers four government-recognised courses. Three are open after 10th standard.
      <strong class="text-slate-900">Welder is open after 8th standard.</strong>
    </p>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {courses.map((c) => (
        <a
          href={`/courses/${c.id}`}
          class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-7 transition hover:-translate-y-0.5 hover:border-maroon-300 hover:shadow-lg"
        >
          <div class="flex items-start justify-between gap-4">
            <span class="text-4xl" aria-hidden="true">{c.data.icon}</span>
            {c.data.highlight && (
              <span class="rounded-md bg-green-100 px-2.5 py-1 text-xs font-bold text-green-800">
                ★ {c.data.highlight}
              </span>
            )}
          </div>

          <h2 class="mt-5 text-2xl font-bold text-slate-900 group-hover:text-maroon-700">
            Become a {c.data.shortName}
          </h2>
          <p class="mt-1 text-sm font-medium text-slate-500">{c.data.name}</p>
          <p class="mt-1 mr text-sm text-slate-500">{c.data.nameMr}</p>

          <p class="mt-4 leading-relaxed text-slate-600">{c.data.summary}</p>

          <dl class="mt-6 grid grid-cols-3 gap-3 border-t border-slate-100 pt-5 text-sm">
            <div>
              <dt class="text-xs font-semibold text-slate-400 uppercase">Eligibility</dt>
              <dd class="mt-0.5 font-bold text-slate-900">{c.data.eligibility}</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold text-slate-400 uppercase">Duration</dt>
              <dd class="mt-0.5 font-bold text-slate-900">{c.data.duration ?? <span class="font-normal text-slate-400">Ask us</span>}</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold text-slate-400 uppercase">Seats</dt>
              <dd class="mt-0.5 font-bold text-slate-900">{c.data.seats ?? <span class="font-normal text-slate-400">Ask us</span>}</dd>
            </div>
          </dl>

          <span class="mt-6 text-sm font-bold text-maroon-700">See details & careers →</span>
        </a>
      ))}
    </div>

    <div class="mt-14 rounded-2xl bg-slate-50 p-8 text-center ring-1 ring-slate-200">
      <h2 class="text-2xl font-bold text-slate-900">Not sure which course to choose?</h2>
      <p class="mt-3 text-slate-600">Call us. We will explain each course, the jobs it leads to, and what suits you.</p>
      <div class="mt-6 flex flex-col justify-center gap-3 sm:flex-row">
        <a href={`tel:${site.phonePrimary}`} class="rounded-xl bg-maroon-700 px-6 py-3.5 font-bold text-white hover:bg-maroon-800">
          📞 Call {site.phonePrimary}
        </a>
        <a href={`https://wa.me/91${site.whatsapp}`} rel="noopener" class="rounded-xl bg-[#25D366] px-6 py-3.5 font-bold text-white hover:brightness-110">
          💬 Ask on WhatsApp
        </a>
      </div>
    </div>
  </div>
</Base>

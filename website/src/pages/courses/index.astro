---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import Picture from '../../components/Picture.astro';
import { site } from '../../config/site';
import { getCollection } from 'astro:content';

const courses = (await getCollection('courses')).sort((a, b) => a.data.order - b.data.order);

const schema = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
      { '@type': 'ListItem', position: 2, name: 'Courses', item: new URL('/courses', Astro.site).href },
    ],
  },
  {
    '@type': 'ItemList',
    itemListElement: courses.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Course',
        name: `${c.data.name} — ITI Course`,
        description: c.data.summary,
        url: new URL(`/courses/${c.id}`, Astro.site).href,
        provider: { '@type': 'EducationalOrganization', name: site.name },
      },
    })),
  },
];
---

<Base
  title={`ITI Courses after 10th & 8th in Akola | ${site.name}`}
  description="ITI courses at Dekson ITI Akola: Electrician, COPA, Solar Technician after 10th, and Welder after 8th pass. NCVT approved. Eligibility, careers and admission details."
  schema={schema}
>
  <div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
    <nav aria-label="Breadcrumb" class="text-sm text-stone-500">
      <a href="/" class="hover:text-navy-700 hover:underline">Home</a>
      <span class="mx-2 text-stone-300">/</span><span class="text-stone-700">Courses</span>
    </nav>

    <div class="hangs mt-8">
      <p class="kicker">Government-recognised training</p>
      <h1 class="mt-2 font-serif text-4xl font-bold text-stone-900 md:text-5xl">Our Courses</h1>
      <p class="mr mt-2 text-lg text-stone-500">आमचे अभ्यासक्रम</p>
    </div>

    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-stone-700">
      Four courses. Three are open after 10th standard.
      <strong class="text-stone-900">Welder is open after 8th standard</strong> — if you left school
      early, you can still learn a trade here.
    </p>

    <div class="mt-12 grid gap-px border border-stone-200 bg-stone-200 md:grid-cols-2">
      {courses.map((c) => (
        <a href={`/courses/${c.id}`} class="group flex flex-col bg-white transition-colors hover:bg-clay-50">
          {c.data.image && (
            <div class="relative aspect-[16/9] overflow-hidden bg-stone-100">
              <Picture src={c.data.image} alt={`${c.data.name} workshop at Dekson ITI`} widths={[640, 1024]} sizes="(max-width: 768px) 100vw, 50vw" class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" width={1024} height={768} />
            </div>
          )}

          <div class="flex flex-col p-8">
          <div class="flex items-start justify-between gap-4">
            <span class="flex h-14 w-14 items-center justify-center border border-stone-300 text-navy-700 transition-colors group-hover:border-navy-700">
              <Icon name={c.data.icon as any} size={24} />
            </span>
            {c.data.highlight && (
              <span class="bg-gold-100 px-2.5 py-1 text-xs font-semibold text-gold-800">{c.data.highlight}</span>
            )}
          </div>

          <h2 class="mt-6 font-serif text-2xl font-bold text-stone-900 group-hover:text-navy-700">
            Become a{/^[aeiouAEIOU]/.test(c.data.shortName) ? "n" : ""} {c.data.shortName}
          </h2>
          <p class="mt-1 text-sm font-medium text-stone-500">{c.data.name}</p>
          <p class="mr mt-1 text-sm text-stone-500">{c.data.nameMr}</p>

          <p class="mt-4 leading-relaxed text-stone-600">{c.data.summary}</p>

          <dl class="mt-7 grid grid-cols-3 gap-4 border-t border-stone-200 pt-5 text-sm">
            <div>
              <dt class="text-xs font-semibold tracking-wide text-stone-400 uppercase">Eligibility</dt>
              <dd class="mt-1 font-semibold text-stone-900">{c.data.eligibility}</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold tracking-wide text-stone-400 uppercase">Duration</dt>
              <dd class="mt-1 font-semibold text-stone-900">{c.data.duration ?? <span class="font-normal text-stone-400">Ask us</span>}</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold tracking-wide text-stone-400 uppercase">Seats</dt>
              <dd class="mt-1 font-semibold text-stone-900">{c.data.seats ?? <span class="font-normal text-stone-400">Ask us</span>}</dd>
            </div>
          </dl>

          <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-navy-700">
            Details and careers <Icon name="arrowRight" size={15} class="transition-transform group-hover:translate-x-1" />
          </span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-14 border-l-4 border-navy-700 bg-stone-50 p-8">
      <h2 class="font-serif text-2xl font-bold text-stone-900">Not sure which course to choose?</h2>
      <p class="mt-3 max-w-xl leading-relaxed text-stone-600">
        Call us. We will explain what each course teaches, the work it leads to, and which one fits
        your schooling.
      </p>
      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a href={`tel:${site.phonePrimary}`} class="inline-flex items-center justify-center gap-2 bg-navy-700 px-6 py-3.5 font-semibold text-white hover:bg-navy-800">
          <Icon name="phone" size={17} />
          <span class="tnum notranslate" translate="no">{site.phonePrimary}</span>
        </a>
        <a href={`https://wa.me/91${site.whatsapp}`} rel="noopener" class="inline-flex items-center justify-center gap-2 border-2 border-stone-300 px-6 py-3.5 font-semibold text-stone-800 hover:border-navy-700 hover:text-navy-700">
          <Icon name="whatsapp" size={17} /> Ask on WhatsApp
        </a>
      </div>
    </div>
  </div>
</Base>

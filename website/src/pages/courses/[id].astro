---
import Base from '../../layouts/Base.astro';
import Fact from '../../components/Fact.astro';
import Picture from '../../components/Picture.astro';
import { site, dvet } from '../../config/site';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  return courses.map((c) => ({ params: { id: c.id }, props: { course: c } }));
}

const { course } = Astro.props;
const { Content } = await render(course);
const d = course.data;

const schema = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
      { '@type': 'ListItem', position: 2, name: 'Courses', item: new URL('/courses', Astro.site).href },
      { '@type': 'ListItem', position: 3, name: d.name, item: new URL(`/courses/${course.id}`, Astro.site).href },
    ],
  },
  {
    '@type': 'Course',
    name: `${d.name} — ITI Course`,
    description: d.summary,
    provider: { '@type': 'EducationalOrganization', name: site.name, sameAs: Astro.site?.href },
    educationalCredentialAwarded: 'NCVT National Trade Certificate',
    ...(d.duration ? { timeRequired: d.duration } : {}),
  },
];
---

<Base
  title={`${d.name} Course in Akola — ${d.eligibility} | ${site.name}`}
  description={`${d.name} ITI course at DEKSON ITI, Akola. Eligibility: ${d.eligibility}. ${d.summary} NCVT approved. Call ${site.phonePrimary}.`}
  schema={schema}
>
  <div class="mx-auto max-w-4xl px-4 py-12">
    <nav aria-label="Breadcrumb" class="text-sm text-slate-500">
      <a href="/" class="hover:text-maroon-700 hover:underline">Home</a>
      <span class="mx-1.5">/</span>
      <a href="/courses" class="hover:text-maroon-700 hover:underline">Courses</a>
      <span class="mx-1.5">/</span><span class="text-slate-700">{d.shortName}</span>
    </nav>

    <header class="mt-6">
      <span class="text-5xl" aria-hidden="true">{d.icon}</span>
      <h1 class="mt-4 text-4xl font-black tracking-tight text-slate-900 md:text-5xl">
        Become a {d.shortName}
      </h1>
      <p class="mt-2 text-lg font-medium text-slate-600">{d.name}</p>
      <p class="mt-1 mr text-lg text-slate-500">{d.nameMr}</p>

      {d.highlight && (
        <p class="mt-5 inline-block rounded-lg bg-green-100 px-4 py-2 text-sm font-bold text-green-800">
          ★ {d.highlight}
        </p>
      )}
    </header>

    <!-- Key facts. Unknowns say "Please call" — never a plausible guess. -->
    <dl class="mt-9 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-slate-50 p-4 ring-1 ring-slate-100">
        <dt class="text-xs font-bold text-slate-400 uppercase">Eligibility</dt>
        <dd class="mt-1 font-bold text-slate-900">{d.eligibility}</dd>
        <dd class="mr text-xs text-slate-500">{d.eligibilityMr}</dd>
      </div>
      <div class="rounded-xl bg-slate-50 p-4 ring-1 ring-slate-100">
        <dt class="text-xs font-bold text-slate-400 uppercase">Duration</dt>
        <dd class="mt-1 font-bold text-slate-900">
          {d.duration ?? <span class="text-sm font-normal text-slate-400">Please call</span>}
        </dd>
      </div>
      <div class="rounded-xl bg-slate-50 p-4 ring-1 ring-slate-100">
        <dt class="text-xs font-bold text-slate-400 uppercase">Seats</dt>
        <dd class="mt-1 font-bold text-slate-900">
          {d.seats ?? <span class="text-sm font-normal text-slate-400">Please call</span>}
        </dd>
      </div>
      <div class="rounded-xl bg-slate-50 p-4 ring-1 ring-slate-100">
        <dt class="text-xs font-bold text-slate-400 uppercase">Yearly fee</dt>
        <dd class="mt-1 font-bold text-slate-900">
          {d.annualFee ?? <span class="text-sm font-normal text-slate-400">Please call</span>}
        </dd>
      </div>
    </dl>

    <div class="prose prose-slate mt-10 max-w-none prose-strong:text-slate-900">
      <Content />
    </div>

    <!-- Jobs -->
    {d.jobs.length > 0 && (
      <section class="mt-14">
        <h2 class="text-2xl font-bold text-slate-900">Jobs you can do after this course</h2>
        <ul class="mt-5 grid gap-2.5 sm:grid-cols-2">
          {d.jobs.map((j) => (
            <li class="flex items-start gap-2.5 rounded-xl bg-slate-50 p-4 text-slate-700 ring-1 ring-slate-100">
              <span class="text-maroon-700" aria-hidden="true">→</span>{j}
            </li>
          ))}
        </ul>
        <p class="mt-5 rounded-lg border-l-4 border-slate-300 bg-slate-50 p-4 text-sm text-slate-600">
          These are the roles this course prepares you for. DEKSON ITI is a new institute and has not
          yet placed any students, so we do not publish placement figures or salary claims.
          <a href="/about" class="font-semibold text-maroon-700 underline">See what support we do provide.</a>
        </p>
      </section>
    )}

    <!-- Workshop photo, or an honest note. Never a stock image of someone else's workshop. -->
    <section class="mt-14">
      <h2 class="text-2xl font-bold text-slate-900">The workshop</h2>
      {d.image ? (
        <div class="mt-5 overflow-hidden rounded-2xl">
          <Picture src={d.image} alt={`${d.name} workshop at ${site.name}, Akola`} class="w-full" width={1024} height={768} />
        </div>
      ) : (
        <div class="mt-5 rounded-2xl border-2 border-dashed border-slate-300 bg-slate-50 p-8 text-center">
          <p class="text-sm text-slate-600">
            Photographs of this workshop will be published shortly.
          </p>
          <p class="mt-2 text-sm text-slate-600">
            We would rather show you nothing than show you a picture of someone else's workshop.
          </p>
          <a href={`tel:${site.phonePrimary}`} class="mt-4 inline-block rounded-lg bg-maroon-700 px-5 py-2.5 text-sm font-bold text-white hover:bg-maroon-800">
            📞 Call to visit the campus
          </a>
        </div>
      )}
    </section>

    <!-- Apply -->
    <section class="mt-14 rounded-2xl border-2 border-maroon-200 bg-maroon-50 p-8 text-center">
      <h2 class="text-2xl font-bold text-slate-900">Apply for {d.shortName}</h2>
      <p class="mt-3 text-sm text-slate-600">
        Enter Institute Code
        <strong class="font-mono text-maroon-700"><Fact value={site.instituteCode} /></strong>
        in your option form at
        <a href={dvet.portal} rel="noopener" class="font-semibold text-maroon-700 underline">admission.dvet.gov.in</a>
      </p>
      <div class="mt-6 flex flex-col justify-center gap-3 sm:flex-row">
        <a href="/admissions" class="rounded-xl bg-maroon-700 px-6 py-3.5 font-bold text-white hover:bg-maroon-800">
          How to apply
        </a>
        <a href={`https://wa.me/91${site.whatsapp}`} rel="noopener" class="rounded-xl bg-[#25D366] px-6 py-3.5 font-bold text-white hover:brightness-110">
          💬 Ask on WhatsApp
        </a>
      </div>
    </section>
  </div>
</Base>

---
import Base from '../../layouts/Base.astro';
import Fact from '../../components/Fact.astro';
import Picture from '../../components/Picture.astro';
import Icon from '../../components/Icon.astro';
import Illustration from '../../components/Illustration.astro';
import { site, dvet } from '../../config/site';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  return courses.map((c) => ({ params: { id: c.id }, props: { course: c } }));
}

const { course } = Astro.props;
const { Content } = await render(course);
const d = course.data;

const schema = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
      { '@type': 'ListItem', position: 2, name: 'Courses', item: new URL('/courses', Astro.site).href },
      { '@type': 'ListItem', position: 3, name: d.name, item: new URL(`/courses/${course.id}`, Astro.site).href },
    ],
  },
  {
    '@type': 'Course',
    name: `${d.name} — ITI Course`,
    description: d.summary,
    provider: { '@type': 'EducationalOrganization', name: site.name, sameAs: Astro.site?.href },
    educationalCredentialAwarded: 'NCVT National Trade Certificate',
    ...(d.duration ? { timeRequired: d.duration } : {}),
  },
];

const facts = [
  { label: 'Eligibility', value: d.eligibility, sub: d.eligibilityMr },
  { label: 'Duration', value: d.duration },
  { label: 'Seats', value: d.seats?.toString() ?? null },
  { label: 'Yearly fee', value: d.annualFee },
];
---

<Base
  title={`${d.name} Course in Akola — ${d.eligibility} | ${site.name}`}
  description={`${d.name} ITI course at DEKSON ITI, Akola. Eligibility: ${d.eligibility}. ${d.summary} NCVT approved. Call ${site.phonePrimary}.`}
  schema={schema}
>
  <div class="mx-auto max-w-4xl px-4 py-12">
    <nav aria-label="Breadcrumb" class="text-sm text-stone-500">
      <a href="/" class="hover:text-maroon-700 hover:underline">Home</a>
      <span class="mx-2 text-stone-300">/</span>
      <a href="/courses" class="hover:text-maroon-700 hover:underline">Courses</a>
      <span class="mx-2 text-stone-300">/</span><span class="text-stone-700">{d.shortName}</span>
    </nav>

    <header class="mt-8 flex flex-col gap-6 sm:flex-row sm:items-start">
      <span class="flex h-16 w-16 shrink-0 items-center justify-center border-2 border-maroon-700 text-maroon-700">
        <Icon name={d.icon as any} size={28} />
      </span>
      <div class="hangs">
        <p class="kicker">{d.eligibility} · Government recognised</p>
        <h1 class="mt-2 font-serif text-4xl font-bold text-stone-900 md:text-5xl">Become a {d.shortName}</h1>
        <p class="mt-2 font-medium text-stone-600">{d.name}</p>
        <p class="mr mt-1 text-stone-500">{d.nameMr}</p>
      </div>
    </header>

    {d.highlight && (
      <p class="mt-6 border-l-4 border-gold-700 bg-gold-50 px-4 py-3 text-sm font-semibold text-gold-800">
        {d.highlight}
      </p>
    )}

    <!-- Illustrative trade photo. The caption is baked into the component and
         states plainly that this is not DEKSON's campus. -->
    {d.illustration && (
      <Illustration course={course.id} variant="full" class="mt-8" sizes="(max-width: 896px) 100vw, 896px" />
    )}

    <!-- Key facts. Unknowns say "Please call" — never a plausible guess. -->
    <dl class="mt-10 grid grid-cols-2 gap-px border border-stone-200 bg-stone-200 sm:grid-cols-4">
      {facts.map((f) => (
        <div class="bg-stone-50 p-5">
          <dt class="text-xs font-semibold tracking-wide text-stone-400 uppercase">{f.label}</dt>
          <dd class="mt-1.5 font-semibold text-stone-900">
            {f.value ?? <span class="text-sm font-normal text-stone-400">Please call</span>}
          </dd>
          {f.sub && <dd class="mr text-xs text-stone-500">{f.sub}</dd>}
        </div>
      ))}
    </dl>

    <div class="prose prose-stone mt-12 max-w-[65ch] prose-headings:font-serif prose-a:text-maroon-700 prose-strong:text-stone-900">
      <Content />
    </div>

    {d.jobs.length > 0 && (
      <section class="mt-16">
        <div class="hangs">
          <p class="kicker">After the course</p>
          <h2 class="mt-2 font-serif text-2xl font-bold text-stone-900">Work you can do</h2>
        </div>
        <ul class="mt-6 grid gap-px border border-stone-200 bg-stone-200 sm:grid-cols-2">
          {d.jobs.map((j) => (
            <li class="flex items-start gap-3 bg-white p-4 text-stone-700">
              <Icon name="arrowRight" size={16} class="mt-1 shrink-0 text-maroon-700" />
              {j}
            </li>
          ))}
        </ul>
        <p class="mt-6 border-l-4 border-stone-300 bg-stone-50 p-4 text-sm leading-relaxed text-stone-600">
          These are the roles this course prepares you for. DEKSON ITI is a new institute and has not
          yet placed any students, so we publish no placement figures and no salary claims.
          <a href="/about" class="font-semibold text-maroon-700 underline">See what support we do provide.</a>
        </p>
      </section>
    )}

    <!-- Workshop photo, or an honest note. Never a stock image. -->
    <section class="mt-16">
      <div class="hangs">
        <p class="kicker">Where you will learn</p>
        <h2 class="mt-2 font-serif text-2xl font-bold text-stone-900">The workshop</h2>
      </div>
      {d.image ? (
        <Picture src={d.image} alt={`${d.name} workshop at ${site.name}, Akola`} class="mt-6 w-full" width={1024} height={768} />
      ) : (
        <div class="mt-6 border-l-4 border-stone-300 bg-stone-50 p-6">
          <p class="leading-relaxed text-stone-700">
            We have not photographed this workshop yet, so we are not showing you a picture of it.
          </p>
          <p class="mt-2 text-sm leading-relaxed text-stone-600">
            We would rather show you nothing than show you someone else's workshop and call it ours.
            Come and see the real one.
          </p>
          <a href={`tel:${site.phonePrimary}`} class="mt-4 inline-flex items-center gap-2 bg-maroon-700 px-5 py-2.5 text-sm font-semibold text-white hover:bg-maroon-800">
            <Icon name="phone" size={15} /> Call to visit the campus
          </a>
        </div>
      )}
    </section>

    <section class="mt-16 border-2 border-maroon-700 p-8 text-center">
      <p class="kicker">Apply</p>
      <h2 class="mt-2 font-serif text-2xl font-bold text-stone-900">Choose {d.shortName} at DEKSON</h2>
      <p class="mt-4 text-sm text-stone-600">Enter this Institute Code in your option form</p>
      <p class="notranslate tnum mt-2 font-serif text-3xl font-bold break-all text-maroon-700" translate="no">
        <Fact value={site.instituteCode} />
      </p>
      <p class="mt-2 text-sm text-stone-500">
        at <a href={dvet.portal} rel="noopener" class="font-semibold text-maroon-700 underline">admission.dvet.gov.in</a>
      </p>
      <div class="mt-7 flex flex-col justify-center gap-3 sm:flex-row">
        <a href="/admissions" class="bg-maroon-700 px-6 py-3.5 font-semibold text-white hover:bg-maroon-800">
          How to apply
        </a>
        <a href={`https://wa.me/91${site.whatsapp}`} rel="noopener" class="inline-flex items-center justify-center gap-2 border-2 border-stone-300 px-6 py-3.5 font-semibold text-stone-800 hover:border-maroon-700 hover:text-maroon-700">
          <Icon name="whatsapp" size={17} /> Ask on WhatsApp
        </a>
      </div>
    </section>
  </div>
</Base>

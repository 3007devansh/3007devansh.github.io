---
import Base from '../layouts/Base.astro';
import Fact from '../components/Fact.astro';
import { site } from '../config/site';
---

<Base title={`Privacy Policy | ${site.name}`} description="How DEKSON ITI, Akola handles personal information.">
  <div class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-4xl font-extrabold text-slate-900">Privacy Policy</h1>

    <div class="mt-8 space-y-6 text-slate-700">
      <p>
        This website is operated by {site.name}, run by {site.runBy}, Waghulgaon, Akola.
      </p>

      <section>
        <h2 class="text-xl font-bold text-slate-900">What we collect</h2>
        <p class="mt-2">
          This website does not currently collect personal information through any form. If you call or message us
          on WhatsApp, we will have your phone number and whatever information you choose to share with us.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-slate-900">How we use it</h2>
        <p class="mt-2">
          We use your contact details only to answer your admission enquiry. We do not sell, rent or share your
          information with anyone outside the institute, and we do not send marketing messages to people who have
          not asked for them.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-slate-900">Students under 18</h2>
        <p class="mt-2">
          Many of our applicants are under 18. If you are under 18, please involve a parent or guardian when you
          contact us or share any personal information.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-slate-900">Your rights</h2>
        <p class="mt-2">
          You may ask us what information we hold about you, ask us to correct it, or ask us to delete it. Contact
          us at <Fact value={site.email} fallback={site.phonePrimary} />.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-slate-900">Contact</h2>
        <p class="mt-2">
          {site.name}, <Fact value={site.addressFull} fallback={site.addressShort} />
          <br />Phone: {site.phonePrimary}
        </p>
      </section>
    </div>
  </div>
</Base>

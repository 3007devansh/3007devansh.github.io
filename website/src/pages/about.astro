---
import Base from '../layouts/Base.astro';
import Fact from '../components/Fact.astro';
import { site, isTodo } from '../config/site';
---

<Base
  title={`About | ${site.name}, Akola`}
  description={`About Dekson ITI, Akola — a DGT/NCVT approved industrial training institute run by ${site.runBy}, serving Akola since 1967.`}
>
  <div class="mx-auto max-w-4xl px-4 py-12">
    <div class="hangs">
      <p class="kicker">About us</p>
      <h1 class="mt-2 font-serif text-4xl font-bold text-stone-900 md:text-5xl">About {site.name}</h1>
      <p class="mr mt-2 text-lg text-stone-500">{site.nameMr}</p>
    </div>

    <div class="mt-8 space-y-4 text-lg leading-relaxed text-stone-700">
      <p>
        {site.nameFull} is a <strong class="text-stone-900">{site.approval}</strong> Industrial Training
        Institute at Babhulgaon, near Shivaji Engineering College, Akola. It is run by
        <strong class="text-stone-900">{site.runBy}</strong> ({site.runByMr}).
      </p>
      <p>
        The institute offers four government-recognised courses — Solar Technician (Electrical),
        Electrician, Computer Operator &amp; Programming Assistant (COPA), and Welder — on a newly
        built, fully constructed campus with well-equipped workshops.
      </p>
    </div>

    <!-- The founding Trust: this is the credibility a new institute stands on. -->
    <section class="mt-12 border-l-4 border-maroon-700 bg-stone-50 p-8">
      <p class="kicker">Our foundation</p>
      <h2 class="mt-2 font-serif text-2xl font-bold text-stone-900">Backed by {site.runBy}</h2>
      <div class="mt-4 space-y-3 leading-relaxed text-stone-700">
        <p>
          Shri Akola Gujarati Samaj Trust has served the Akola community since
          <strong class="text-stone-900">1967</strong> — more than five decades of social and
          educational work.
        </p>
        <p>
          {site.samajOtherInstitutions} With Dekson ITI, the Trust extends that work into skill
          training, helping young people in and around Akola learn a trade and earn a living.
        </p>
      </div>
    </section>

    <!-- Principal's message. Names only, no photographs (decided). -->
    <section class="mt-12">
      <div class="hangs">
        <p class="kicker">From the Principal</p>
        <h2 class="mt-2 font-serif text-2xl font-bold text-stone-900">Principal's Message</h2>
      </div>
      <figure class="mt-6 border border-stone-200 p-8">
        <blockquote class="text-lg leading-relaxed text-stone-700">
          "{site.principalMessage}"
        </blockquote>
        <figcaption class="mt-5 border-t border-stone-200 pt-4">
          <span class="font-semibold text-stone-900">{site.principalName}</span>
          <span class="text-stone-500"> · {site.principalTitle}, {site.name}</span>
        </figcaption>
      </figure>
    </section>

    {/* Chairman's message hidden until supplied — no red placeholder on a public page. */}
    {!isTodo(site.chairmanMessage) && (
      <section class="mt-8">
        <figure class="border border-stone-200 p-8">
          <p class="kicker">From the Chairman</p>
          <blockquote class="mt-4 text-lg leading-relaxed text-stone-700">
            "<Fact value={site.chairmanMessage} />"
          </blockquote>
          <figcaption class="mt-5 border-t border-stone-200 pt-4 font-semibold text-stone-900">
            <Fact value={site.chairmanName} />
          </figcaption>
        </figure>
      </section>
    )}

    <!-- Career support: future tense, clearly a commitment not a record. -->
    <section class="mt-12">
      <div class="hangs">
        <p class="kicker">After the course</p>
        <h2 class="mt-2 font-serif text-2xl font-bold text-stone-900">Career support</h2>
      </div>
      <p class="mt-4 leading-relaxed text-stone-700">
        No institute can honestly guarantee a job, and we will not claim to. Dekson ITI is a new
        institute, so we have no placement record yet and we publish no placement figures. What we do
        commit to:
      </p>
      <ul class="mt-4 grid gap-px border border-stone-200 bg-stone-200 sm:grid-cols-2">
        {[
          'Practical, hands-on training in well-equipped workshops',
          'Help with apprenticeship registration, including under NAPS',
          'Guidance on further study after ITI',
          'Support in approaching local industry for work',
        ].map((item) => (
          <li class="flex items-start gap-3 bg-white p-4 text-stone-700">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 bg-maroon-700" aria-hidden="true"></span>{item}
          </li>
        ))}
      </ul>
    </section>

    <!-- Verify-us invitation: a trust signal a scam site never offers. -->
    <section class="mt-12 border-2 border-maroon-700 p-8 text-center">
      <h2 class="font-serif text-2xl font-bold text-stone-900">Don't just take our word for it</h2>
      <p class="mx-auto mt-3 max-w-xl leading-relaxed text-stone-600">
        Our approval is real and you can check it yourself on the NCVT MIS portal. Better still, visit
        the campus, meet us, and ask anything you like before you decide.
      </p>
      <div class="mt-6 flex flex-col justify-center gap-3 sm:flex-row">
        <a href={`tel:${site.phonePrimary}`} class="bg-maroon-700 px-6 py-3 font-semibold text-white hover:bg-maroon-800">
          Call <span class="tnum notranslate ml-1" translate="no">{site.phonePrimary}</span>
        </a>
        <a href="/contact" class="border-2 border-stone-300 px-6 py-3 font-semibold text-stone-800 hover:border-maroon-700 hover:text-maroon-700">
          Visit the campus
        </a>
      </div>
    </section>
  </div>
</Base>

---
import Base from '../layouts/Base.astro';
import Fact from '../components/Fact.astro';
import Picture from '../components/Picture.astro';
import { site, dvet } from '../config/site';
import { getCollection } from 'astro:content';

const courses = (await getCollection('courses')).sort((a, b) => a.data.order - b.data.order);

const facilities = [
  'Well-equipped workshops', 'Classrooms', 'Computer lab', 'Library',
  'Auditorium', 'Amphitheatre', 'Seminar hall', 'Reception',
  'Staff room', 'Drinking water', 'Separate washrooms', 'Canteen',
  'Parking', 'CCTV', 'Security guard', 'Ramp access',
  'First aid', 'Fire safety',
];

const schema = [
  {
    '@type': 'ItemList',
    itemListElement: courses.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Course',
        name: `${c.data.name} — ITI Course`,
        description: c.data.summary,
        url: new URL(`/courses/${c.id}`, Astro.site).href,
        provider: { '@type': 'EducationalOrganization', name: site.name, sameAs: Astro.site?.href },
      },
    })),
  },
];

const fmt = (d: string) =>
  new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
---

<Base
  title={`${site.name}, Akola — ${site.approval} ITI | Admissions ${site.admission.year} Open`}
  description={`${site.approval} ITI in Babhulgaon, Akola. Courses after 10th: Electrician, COPA, Solar Technician. Welder after 8th. Run by ${site.runBy}. Call ${site.phonePrimary}.`}
  schema={schema}
>
  <!-- Admissions band. Gold reads as a seal; the traffic-light green it replaced
       read as a chat notification. -->
  <div class="border-b border-gold-300 bg-gold-100">
    <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-x-2 gap-y-1 px-4 py-2.5 text-center">
      <span class="kicker text-gold-800">Admissions {site.admission.year}</span>
      <span class="text-sm text-stone-800">
        <Fact value={site.admission.statusLine} fallback="Institute-level seats are open now." />
      </span>
      <a href="/admissions" class="text-sm font-semibold text-navy-700 underline underline-offset-2">
        How to apply
      </a>
    </div>
  </div>

  <!--
    HERO — split, not overlay.
    The previous version dimmed the real campus photo to 30% opacity to float a
    slogan over it. For a trust-first audience that is backwards: the building
    is the evidence. Full brightness, hard edges, no rounding.
  -->
  <section class="border-b border-stone-200">
    <div class="mx-auto grid max-w-6xl lg:grid-cols-12">
      <div class="bg-clay-50 px-4 py-12 sm:px-8 lg:col-span-5 lg:py-20">
        <p class="kicker">Babhulgaon · Akola · Maharashtra</p>

        <h1 class="mt-4 font-serif text-4xl leading-[1.1] font-bold text-stone-900 md:text-5xl">
          Learn a skill.<br />Earn a living.
        </h1>
        <p class="mr mt-3 text-lg text-stone-600">{site.nameMr}</p>

        <p class="mt-6 max-w-md leading-relaxed text-stone-700">
          A government-recognised Industrial Training Institute run by {site.runBy}.
          Practical training, a certificate valid across India, and a real trade in your hands.
        </p>

        <!-- Eligibility as a labelled data list, not floating pills -->
        <dl class="mt-8 border-t border-stone-200">
          <div class="flex gap-4 border-b border-stone-200 py-3">
            <dt class="w-28 shrink-0 text-xs font-semibold tracking-wide text-stone-500 uppercase">After 10th</dt>
            <dd class="text-sm font-medium text-stone-800">Electrician · COPA · Solar Technician</dd>
          </div>
          <div class="flex gap-4 border-b border-stone-200 py-3">
            <dt class="w-28 shrink-0 text-xs font-semibold tracking-wide text-stone-500 uppercase">After 8th</dt>
            <dd class="text-sm font-medium text-stone-800">
              Welder
              <span class="ml-1 bg-gold-100 px-1.5 py-0.5 text-xs font-semibold text-gold-800">no 10th needed</span>
            </dd>
          </div>
        </dl>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href={`tel:${site.phonePrimary}`} class="inline-flex items-center justify-center bg-navy-700 px-6 py-3.5 font-semibold text-white transition-colors hover:bg-navy-800">
            Call <span class="tnum notranslate ml-1.5" translate="no">{site.phonePrimary}</span>
          </a>
          <a href={`https://wa.me/91${site.whatsapp}`} rel="noopener" class="inline-flex items-center justify-center border-2 border-stone-300 px-6 py-3.5 font-semibold text-stone-800 transition-colors hover:border-navy-700 hover:text-navy-700">
            Message on WhatsApp
          </a>
        </div>
      </div>

      <!-- The photograph, at full brightness. It is evidence, not wallpaper. -->
      <div class="relative min-h-[280px] lg:col-span-7 lg:min-h-[520px]">
        <Picture
          src="campus-entrance"
          alt="The main entrance building of Dekson ITI at Babhulgaon, Akola"
          priority={true}
          sizes="(max-width: 1024px) 100vw, 58vw"
          class="absolute inset-0 h-full w-full object-cover"
          width={1600}
          height={1200}
        />
      </div>
    </div>
  </section>

  <!--
    Accreditation strip — the single most important trust device on an Indian
    ITI site, near the fold. Official Skill India + ITI marks; DGT/NCVT and DVET
    as text seals. Full colour on white, equal height, generously spaced.
  -->
  <section aria-label="Recognitions & Affiliations" class="border-b border-stone-200 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-8">
      <p class="kicker text-center text-stone-400">Recognised &amp; affiliated by</p>
      <div class="mt-5 flex flex-wrap items-center justify-center gap-x-10 gap-y-6">
        <img src="/images/accred-skillindia.png" alt="Skill India" width="146" height="120" class="h-14 w-auto object-contain" loading="lazy" />
        <img src="/images/accred-iti.png" alt="Industrial Training Institute (ITI)" width="180" height="120" class="h-14 w-auto object-contain" loading="lazy" />
        <span class="border-l border-stone-200 pl-8 text-center">
          <span class="block font-serif text-base font-bold text-navy-800">DGT / NCVT</span>
          <span class="block text-xs text-stone-500">New Delhi</span>
        </span>
        <span class="text-center">
          <span class="block font-serif text-base font-bold text-navy-800">DVET</span>
          <span class="block text-xs text-stone-500">Maharashtra State</span>
        </span>
      </div>
    </div>
  </section>

  <!-- Credential plaque + notice ledger.
       The institute code is the most important datum on the site; it gets the
       serif display face, not font-mono (monospace-as-decoration is a dev tell). -->
  <section class="bg-stone-50">
    <div class="mx-auto grid max-w-6xl gap-px bg-stone-200 lg:grid-cols-5">
      <div class="bg-stone-50 p-8 lg:col-span-2">
        <p class="kicker">Our Institute Code</p>
        <div class="mt-3 border-2 border-navy-700 bg-white px-5 py-6 text-center">
          <p class="notranslate font-serif text-3xl font-bold break-all text-navy-700 tnum" translate="no">
            <Fact value={site.instituteCode} />
          </p>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-stone-600">
          Enter this code in your option form at
          <a href={dvet.portal} rel="noopener" class="font-semibold text-navy-700 underline">admission.dvet.gov.in</a>
          to choose {site.name}.
        </p>
      </div>

      <!-- A notice board should look like a notice board: a ledger of dated
           rows. Not a rounded card with a drop shadow. -->
      <div class="bg-white p-8 lg:col-span-3">
        <div class="flex items-baseline justify-between border-b-2 border-navy-700 pb-2">
          <p class="kicker">Latest Notices</p>
          <span class="text-xs text-stone-400">Updated {fmt(site.notices[0].date)}</span>
        </div>
        <ul>
          {site.notices.map((n) => (
            <li class="border-b border-stone-200">
              <a href={n.href} class="group flex flex-col gap-1 py-3 sm:flex-row sm:items-baseline sm:gap-5">
                <time datetime={n.date} class="tnum notranslate w-24 shrink-0 text-xs font-semibold text-stone-400" translate="no">
                  {fmt(n.date)}
                </time>
                <span class="text-sm leading-relaxed text-stone-700 group-hover:text-navy-700 group-hover:underline">
                  {n.text}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- COURSES -->
  <section class="mx-auto max-w-6xl px-4 py-20">
    <div class="grid gap-6 lg:grid-cols-12">
      <div class="hangs lg:col-span-8">
        <p class="kicker">What you can study</p>
        <h2 class="mt-2 font-serif text-3xl font-bold text-stone-900 md:text-4xl">Our Courses</h2>
        <p class="mt-3 max-w-xl leading-relaxed text-stone-600">
          Four government-recognised courses. Each one teaches a practical trade and ends in a
          certificate recognised across India.
        </p>
      </div>
      <div class="flex items-end lg:col-span-4 lg:justify-end">
        <a href="/courses" class="text-sm font-semibold text-navy-700 hover:underline">
          All courses &rarr;
        </a>
      </div>
    </div>

    <div class="mt-10 grid gap-px border border-stone-200 bg-stone-200 sm:grid-cols-2 lg:grid-cols-4">
      {courses.map((c) => (
        <a href={`/courses/${c.id}`} class="group flex flex-col bg-white transition-colors hover:bg-clay-50">
          {c.data.image && (
            <div class="relative aspect-[4/3] overflow-hidden bg-stone-100">
              <Picture src={c.data.image} alt={`${c.data.name} workshop at Dekson ITI`} widths={[640, 1024]} sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 25vw" class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" width={1024} height={768} />
            </div>
          )}
          <div class="flex flex-1 flex-col p-6">
            <h3 class="font-serif text-xl leading-snug font-bold text-stone-900 group-hover:text-navy-700">
              Become a{/^[aeiouAEIOU]/.test(c.data.shortName) ? "n" : ""} {c.data.shortName}
            </h3>
            <p class="mr mt-1 text-xs text-stone-500">{c.data.nameMr}</p>
            <p class="mt-3 text-sm leading-relaxed text-stone-600">{c.data.summary}</p>

            <div class="mt-5 border-t border-stone-200 pt-3">
              <span class="text-xs font-semibold tracking-wide text-stone-500 uppercase">Eligibility</span>
              <p class="mt-0.5 text-sm font-semibold text-stone-800">{c.data.eligibility}</p>
            </div>
            {c.data.highlight && (
              <p class="mt-3 bg-gold-100 px-2 py-1 text-xs font-semibold text-gold-800">{c.data.highlight}</p>
            )}
          </div>
        </a>
      ))}
    </div>

    <p class="mt-4 text-xs text-stone-400">
      Photographs are of the workshops and labs at Dekson ITI, Babhulgaon.
      <a href="/gallery" class="underline hover:text-navy-700">See the full gallery</a>.
    </p>
  </section>

  <!-- TRUST. Not three equal cards: "government recognised" is the load-bearing
       claim and gets a wide band; the other two sit beneath it. -->
  <section class="border-y border-stone-200 bg-stone-50 py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="hangs">
        <p class="kicker">Why DEKSON</p>
        <h2 class="mt-2 font-serif text-3xl font-bold text-stone-900 md:text-4xl">
          We are new. Here is what we can prove.
        </h2>
        <p class="mt-3 max-w-2xl leading-relaxed text-stone-600">
          We have no past results and no placement record, and we will not pretend otherwise.
          Instead, judge us on what can be checked.
        </p>
      </div>

      <div class="mt-10 border-l-4 border-verified-700 bg-white p-8">
        <p class="text-xs font-semibold tracking-[0.12em] text-verified-700 uppercase">The load-bearing fact</p>
        <h3 class="mt-2 font-serif text-2xl font-bold text-stone-900">Government recognised</h3>
        <p class="mt-2 max-w-2xl leading-relaxed text-stone-600">
          Dekson ITI is <strong class="text-stone-900">{site.approval}</strong>. Your certificate is
          valid across India. You do not have to take our word for it —
          <strong class="text-stone-900">verify our approval yourself</strong> on the NCVT MIS portal
          before you pay a rupee.
        </p>
      </div>

      <div class="mt-6 grid gap-6 md:grid-cols-2">
        <div class="border-l-4 border-navy-700 bg-white p-8">
          <h3 class="font-serif text-xl font-bold text-stone-900">A campus that already exists</h3>
          <p class="mt-2 leading-relaxed text-stone-600">
            Fully built and ready — classrooms, workshops, a computer lab, library and auditorium.
            Come and walk through it before you decide. That offer is open to anyone.
          </p>
        </div>
        <div class="border-l-4 border-navy-700 bg-white p-8">
          <h3 class="font-serif text-xl font-bold text-stone-900">Backed by {site.runBy}</h3>
          <p class="mt-2 leading-relaxed text-stone-600">
            The institute was established by a Samaj that has served Akola since
            <Fact value={site.samajFounded} fallback="many years" />.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Full-bleed photo band. Architecture wants right angles and room to breathe. -->
  <section aria-label="Campus" class="bleed">
    <Picture
      src="campus-building"
      alt="The main academic building of Dekson ITI, Akola"
      sizes="100vw"
      class="h-[280px] w-full object-cover md:h-[440px]"
      width={1600}
      height={1200}
    />
  </section>

  <section class="mx-auto max-w-6xl px-4 py-20">
    <div class="hangs">
      <p class="kicker">On campus</p>
      <h2 class="mt-2 font-serif text-3xl font-bold text-stone-900 md:text-4xl">Facilities</h2>
    </div>

    <!-- A small navy rule instead of an icon: a spec sheet, not a feature grid. -->
    <ul class="mt-10 grid grid-cols-2 gap-px border border-stone-200 bg-stone-200 sm:grid-cols-3 lg:grid-cols-4">
      {facilities.map((label) => (
        <li class="flex items-center gap-3 bg-white px-4 py-3.5 text-sm text-stone-700">
          <span class="h-3 w-0.5 shrink-0 bg-navy-700" aria-hidden="true"></span>
          {label}
        </li>
      ))}
    </ul>
    <p class="mt-4 text-sm text-stone-500">The institute does not have a hostel.</p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      <Picture src="workshop-arch" alt="The workshop entrance archway at Dekson ITI" widths={[640, 1024]} sizes="(max-width:640px) 100vw, 50vw" class="h-64 w-full object-cover" width={1024} height={768} />
      <Picture src="main-gate" alt="The main gate of Dekson ITI, Babhulgaon" widths={[640, 1024]} sizes="(max-width:640px) 100vw, 50vw" class="h-64 w-full object-cover" width={1024} height={768} />
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-navy-800">
    <div class="mx-auto max-w-4xl px-4 py-20 text-center">
      <p class="kicker text-gold-300">Talk to us</p>
      <h2 class="mt-3 font-serif text-3xl font-bold text-white md:text-4xl">
        Have a question about admission?
      </h2>
      <p class="mx-auto mt-4 max-w-xl leading-relaxed text-clay-100">
        The online process confuses most students. Call us and we will take you through it,
        step by step, in Marathi.
      </p>

      <div class="mt-10 grid gap-px bg-navy-700 sm:grid-cols-2">
        {[
          { name: site.phonePrimaryName, num: site.phonePrimary },
          { name: site.phoneSecondaryName, num: site.phoneSecondary },
        ].map((p) => (
          <a href={`tel:${p.num}`} class="flex flex-col items-center bg-navy-800 px-6 py-7 transition-colors hover:bg-navy-900">
            <span class="text-xs font-semibold tracking-[0.12em] text-gold-300 uppercase">Call</span>
            <span class="tnum notranslate mt-2 font-serif text-2xl font-bold text-white" translate="no">{p.num}</span>
            <span class="mt-1 text-sm text-clay-300">{p.name}</span>
          </a>
        ))}
      </div>

      <p class="mt-8 text-sm text-clay-300">
        Or <a href="/contact" class="font-semibold text-white underline underline-offset-2">visit the campus</a> —
        you are welcome on any working day.
      </p>
    </div>
  </section>
</Base>

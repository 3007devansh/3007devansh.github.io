---
import Base from '../layouts/Base.astro';
import { site, dvet } from '../config/site';

/**
 * Only questions we can answer truthfully from verified sources
 * (the institute pamphlet + the DVET booklet) appear here.
 * More will be added as the college returns the priority answer sheet.
 */
const faqs = [
  {
    q: 'Are admissions still open? Can I join now?',
    a: `Yes. Admissions are open now — CAP Round 2 and Management Quota seats are available. The easiest first step is to call ${site.phonePrimary} or visit the campus; we will tell you which courses have seats and guide you through the process.`,
  },
  {
    q: 'Which courses does Dekson ITI offer?',
    a: 'Four government-recognised courses: Solar Technician (Electrical) — 40 seats, Electrician — 20 seats, Computer Operator & Programming Assistant (COPA) — 48 seats, and Welder — 40 seats.',
  },
  {
    q: 'How long is each course?',
    a: 'Electrician is a 2-year course. Solar Technician, COPA and Welder are each 1-year courses.',
  },
  {
    q: 'What is the minimum qualification to join?',
    a: 'Solar Technician, Electrician and COPA require 10th pass. Welder is open to students who have passed 8th standard.',
  },
  {
    q: 'Can I join if I did not complete 10th standard?',
    a: 'Yes — the Welder course is open to students who have passed 8th standard. This is a real path to a skilled job if you left school early.',
  },
  {
    q: 'How do I apply?',
    a: `You can apply through the Maharashtra DVET portal at admission.dvet.gov.in — register, fill the option form and enter our Institute Code ${site.instituteCode}. Or simply call ${site.phonePrimary} or visit the campus, and we will help you with every step, including the Management Quota. See our Admissions page for details.`,
  },
  {
    q: 'What is the Institute Code for Dekson ITI?',
    a: `Our Institute Code is ${site.instituteCode}. Enter this in your DVET option form to choose Dekson ITI.`,
  },
  {
    q: 'Do I have to apply online, or can I come in person?',
    a: 'Both. Many students apply through the DVET portal online. You are also welcome to come to the campus directly — we will look at your marks and explain your options, including Management Quota seats. Either way, you visit the institute in person with your documents to confirm the admission.',
  },
  {
    q: 'Which documents must I bring?',
    a: `${dvet.documentsAtAdmission.join('; ')}. If your documents are not ready, you are given ${dvet.documentGraceDays} days, after which the admission is cancelled.`,
  },
  {
    q: 'Will my original certificates be returned?',
    a: dvet.documentsRetained + ' All other certificates are checked against the originals and returned to you at the time of admission.',
  },
  {
    q: 'Can I pay the fee in instalments?',
    a: dvet.instalmentsAllowed + ` Please call ${site.phonePrimary} to discuss.`,
  },
  {
    q: 'Is the certificate valid all over India?',
    a: 'Yes. Dekson ITI is NCVT approved, and an NCVT certificate is recognised across India.',
  },
  {
    q: 'How can I verify that Dekson ITI is government approved?',
    a: 'You can check our affiliation yourself on the NCVT MIS portal, and you will find us listed on the Maharashtra DVET admission portal. Please ask us for our approval documents at any time — we will show them to you.',
  },
  {
    q: 'What facilities are there on campus?',
    a: 'Classrooms, a computer lab, library, auditorium, seminar hall, reception, staff room, canteen, parking, drinking water, separate washrooms, ramp access, first aid, fire safety, CCTV and a security guard. The campus is newly built and fully constructed.',
  },
  {
    q: 'Is the campus safe?',
    a: 'The campus has CCTV cameras, a security guard, first aid and fire safety equipment. Ragging is strictly prohibited and is a criminal offence. Complaints can be made directly to our Anti-Ragging contact, listed on the Contact page.',
  },
  {
    q: 'Do you guarantee a job after the course?',
    a: 'No. No institute can honestly guarantee anyone a job, and we will not claim to. We are a new institute and our first batch has not yet completed the course, so we do not publish placement figures. What we do provide is practical training, help with apprenticeship registration including NAPS, and support in approaching local industry.',
  },
  {
    q: 'You are a new college. Why should I trust you?',
    a: `We will not pretend to have a history we do not have. What we can offer is: our NCVT approval, which you can verify yourself; a fully built campus that you are welcome to visit before deciding; and the backing of ${site.runBy}. Come and see the campus, ask us difficult questions, and then decide.`,
  },
  {
    q: 'Do you work through admission agents?',
    a: `No. Dekson ITI does not work through any agent or middleman, and nobody is authorised to collect money on our behalf. Pay fees only at the institute and always take a receipt. If anyone asks you for money to arrange a seat, please call ${site.phonePrimary}.`,
  },
  {
    q: 'Can I visit the campus before deciding?',
    a: `Yes, and we encourage it. Call ${site.phonePrimary} to arrange a visit.`,
  },
];

/**
 * Google discontinued FAQPage *rich results* on 7 May 2026.
 * This markup no longer produces the SERP accordion. We keep it because Google
 * still parses it to understand the page, and other engines still use it —
 * but no SEO strategy here depends on it.
 */
const schema = [
  {
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
      { '@type': 'ListItem', position: 2, name: 'FAQ', item: new URL('/faq', Astro.site).href },
    ],
  },
];
---

<Base
  title={`ITI Admission FAQ — Akola | ${site.name}`}
  description="Answers about ITI admission in Akola: eligibility after 10th and 8th, DVET portal process, documents, fees, and facilities at Dekson ITI."
  schema={schema}
>
  <div class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="font-serif text-4xl font-bold text-stone-900">Frequently Asked Questions</h1>
    <p class="mt-3 text-stone-600">
      If your question is not answered here, please call
      <a href={`tel:${site.phonePrimary}`} class="font-semibold text-navy-700 underline">{site.phonePrimary}</a>.
    </p>

    <div class="mt-10 space-y-3">
      {faqs.map((f) => (
        <details class="group border border-stone-200 p-5 open:bg-stone-50">
          <summary class="cursor-pointer list-none font-semibold text-stone-900 marker:content-none">
            <span class="flex items-start justify-between gap-4">
              {f.q}
              <span class="shrink-0 text-navy-700 transition group-open:rotate-45">＋</span>
            </span>
          </summary>
          <p class="mt-3 text-stone-700">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</Base>

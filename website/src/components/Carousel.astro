---
/**
 * Auto-rotating image carousel (cross-fade). Vanilla JS, ~1KB.
 * - Pauses on hover/focus and when the tab is hidden.
 * - Respects prefers-reduced-motion (no auto-advance; manual only).
 * - Prev/next buttons + dots, all keyboard reachable.
 */
import Picture from './Picture.astro';

interface Slide { src: string; cap: string }
interface Props {
  slides: Slide[];
  class?: string;
  interval?: number;
  ratio?: string;
}
const { slides, class: className = '', interval = 4000, ratio = 'aspect-[16/9]' } = Astro.props;
---

<div
  class:list={['dk-carousel relative overflow-hidden bg-stone-900', ratio, className]}
  data-interval={interval}
  role="group"
  aria-roledescription="carousel"
  aria-label="Campus facilities"
>
  {slides.map((s, i) => (
    <div
      class:list={['dk-slide absolute inset-0 transition-opacity duration-700', i === 0 ? 'opacity-100' : 'opacity-0']}
      data-idx={i}
      aria-hidden={i === 0 ? 'false' : 'true'}
    >
      <Picture
        src={s.src}
        alt={s.cap}
        widths={[640, 1024]}
        sizes="(max-width: 1152px) 100vw, 1152px"
        priority={i === 0}
        class="h-full w-full object-cover"
        width={1024}
        height={576}
      />
      <div class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 to-transparent p-5 pt-16">
        <p class="text-sm font-semibold text-white sm:text-base">{s.cap}</p>
      </div>
    </div>
  ))}

  <!-- Controls -->
  <button type="button" class="dk-prev absolute top-1/2 left-2 z-10 flex h-10 w-10 -translate-y-1/2 items-center justify-center bg-white/85 text-navy-800 shadow hover:bg-white" aria-label="Previous image">
    <span aria-hidden="true" class="text-xl leading-none">‹</span>
  </button>
  <button type="button" class="dk-next absolute top-1/2 right-2 z-10 flex h-10 w-10 -translate-y-1/2 items-center justify-center bg-white/85 text-navy-800 shadow hover:bg-white" aria-label="Next image">
    <span aria-hidden="true" class="text-xl leading-none">›</span>
  </button>

  <div class="dk-dots absolute bottom-3 left-1/2 z-10 flex -translate-x-1/2 gap-2" role="tablist" aria-label="Choose image">
    {slides.map((_, i) => (
      <button type="button" class:list={['dk-dot h-2.5 w-2.5 rounded-full ring-1 ring-white/70', i === 0 ? 'bg-white' : 'bg-white/30']} data-dot={i} role="tab" aria-label={`Image ${i + 1}`} aria-selected={i === 0 ? 'true' : 'false'} />
    ))}
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.dk-carousel').forEach((root) => {
    const slides = Array.from(root.querySelectorAll<HTMLElement>('.dk-slide'));
    const dots = Array.from(root.querySelectorAll<HTMLElement>('.dk-dot'));
    const interval = Number(root.dataset.interval) || 4000;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let i = 0;
    let timer: ReturnType<typeof setInterval> | null = null;

    const show = (n: number) => {
      i = (n + slides.length) % slides.length;
      slides.forEach((s, k) => {
        const on = k === i;
        s.style.opacity = on ? '1' : '0';
        s.setAttribute('aria-hidden', on ? 'false' : 'true');
      });
      dots.forEach((d, k) => {
        d.classList.toggle('bg-white', k === i);
        d.classList.toggle('bg-white/30', k !== i);
        d.setAttribute('aria-selected', k === i ? 'true' : 'false');
      });
    };
    const next = () => show(i + 1);
    const prev = () => show(i - 1);
    const start = () => { if (!reduce && !timer) timer = setInterval(next, interval); };
    const stop = () => { if (timer) { clearInterval(timer); timer = null; } };

    root.querySelector('.dk-next')?.addEventListener('click', () => { next(); });
    root.querySelector('.dk-prev')?.addEventListener('click', () => { prev(); });
    dots.forEach((d) => d.addEventListener('click', () => show(Number(d.dataset.dot))));

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    root.addEventListener('focusin', stop);
    root.addEventListener('focusout', start);
    document.addEventListener('visibilitychange', () => (document.hidden ? stop() : start()));

    start();
  });
</script>

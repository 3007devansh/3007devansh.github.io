---
import '../styles/global.css';
import Seo from '../components/Seo.astro';
import Icon from '../components/Icon.astro';
import Crest from '../components/Crest.astro';
import LanguageToggle from '../components/LanguageToggle.astro';
import { site } from '../config/site';

interface Props {
  title: string;
  description: string;
  schema?: Record<string, unknown>[];
  ogImage?: string;
}
const { title, description, schema, ogImage } = Astro.props;

const nav = [
  { href: '/', label: 'Home' },
  { href: '/courses', label: 'Courses' },
  { href: '/admissions', label: 'Admissions' },
  { href: '/about', label: 'About' },
  { href: '/faq', label: 'FAQ' },
  { href: '/contact', label: 'Contact' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- TODO: self-host these woff2 files to remove the third-party request. -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,600;8..60,700&family=Inter:wght@400;500;600&family=Mukta:wght@400;600;700&display=swap"
    />

    <Seo title={title} description={description} schema={schema} ogImage={ogImage} />
  </head>

  <body class="bg-white font-sans antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:shadow-lg"
      >Skip to content</a
    >

    <!-- Utility strip. Recognition and phone, gazette-style: this audience is
         verifying we are real before they read anything else. -->
    <div class="bg-maroon-900 text-white">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-1.5">
        <p class="flex items-center gap-2 text-xs">
          <Icon name="shield" size={14} class="shrink-0 text-gold-300" />
          <span class="font-semibold">{site.approval}</span>
          <span class="hidden text-white/50 sm:inline">· {site.runBy}</span>
        </p>
        <div class="flex items-center gap-3">
          <LanguageToggle />
          <a href={`tel:${site.phonePrimary}`} class="hidden items-center gap-1.5 text-xs font-semibold sm:flex">
            <Icon name="phone" size={13} />
            <span class="tnum notranslate" translate="no">{site.phonePrimary}</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Masthead. Solid, opaque, 3px maroon top rule. No backdrop-blur:
         frosted glass is an app signature, not an institutional one. -->
    <header class="sticky top-0 z-30 border-t-[3px] border-maroon-700 bg-white shadow-[0_1px_0_var(--color-stone-200)]">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
        <a href="/" class="flex items-center gap-3">
          <Crest size={42} class="shrink-0" />
          <span class="flex flex-col leading-tight">
            <span class="font-serif text-xl font-bold text-maroon-800">{site.name}</span>
            <!-- Bilingual masthead: real Indian institutions name themselves in
                 both scripts. This is authenticity, not decoration. -->
            <span class="mr text-xs leading-snug text-stone-600">{site.nameMr}</span>
          </span>
        </a>

        <nav aria-label="Main" class="hidden items-center lg:flex">
          {
            nav.map((i) => (
              <a
                href={i.href}
                aria-current={isActive(i.href) ? 'page' : undefined}
                class:list={[
                  'border-b-2 px-3.5 py-2 text-sm font-semibold transition-colors',
                  isActive(i.href)
                    ? 'border-maroon-700 text-maroon-800'
                    : 'border-transparent text-stone-600 hover:border-stone-300 hover:text-maroon-700',
                ]}
              >
                {i.label}
              </a>
            ))
          }
          <a
            href={`tel:${site.phonePrimary}`}
            class="ml-4 inline-flex items-center gap-2 bg-maroon-700 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-maroon-800"
          >
            <Icon name="phone" size={15} /> Call Now
          </a>
        </nav>
      </div>

      <nav aria-label="Sections" class="flex overflow-x-auto border-t border-stone-200 px-2 lg:hidden">
        {
          nav.map((i) => (
            <a
              href={i.href}
              aria-current={isActive(i.href) ? 'page' : undefined}
              class:list={[
                'shrink-0 border-b-2 px-3 py-2.5 text-sm font-semibold whitespace-nowrap transition-colors',
                isActive(i.href) ? 'border-maroon-700 text-maroon-800' : 'border-transparent text-stone-600',
              ]}
            >
              {i.label}
            </a>
          ))
        }
      </nav>
    </header>

    <main id="main"><slot /></main>

    <footer class="mt-24 border-t-[3px] border-maroon-700 bg-stone-50">
      <div class="mx-auto grid max-w-6xl gap-10 px-4 py-14 sm:grid-cols-2 lg:grid-cols-4">
        <div class="sm:col-span-2 lg:col-span-1">
          <div class="flex items-center gap-3">
            <Crest size={38} />
            <div>
              <p class="font-serif text-lg font-bold text-maroon-800">{site.name}</p>
              <p class="mr text-xs text-stone-600">{site.nameMr}</p>
            </div>
          </div>
          <p class="mt-4 text-sm text-stone-600">Run by {site.runBy}</p>
          <p class="mt-4 inline-flex items-center gap-2 border border-maroon-700 px-3 py-1.5 text-xs font-semibold tracking-wide text-maroon-800">
            <Icon name="shield" size={13} />{site.approval}
          </p>
        </div>

        <div class="text-sm">
          <p class="kicker">Contact</p>
          <address class="mt-4 space-y-2 text-stone-600 not-italic">
            <p>{site.addressShort}</p>
            <p><a href={`tel:${site.phonePrimary}`} class="tnum notranslate font-semibold text-maroon-700 hover:underline" translate="no">{site.phonePrimary}</a></p>
            <p><a href={`tel:${site.phoneSecondary}`} class="tnum notranslate font-semibold text-maroon-700 hover:underline" translate="no">{site.phoneSecondary}</a></p>
          </address>
        </div>

        <div class="text-sm">
          <p class="kicker">Pages</p>
          <ul class="mt-4 space-y-2">
            {nav.slice(1).map((i) => (
              <li><a href={i.href} class="text-stone-600 hover:text-maroon-700 hover:underline">{i.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="text-sm">
          <p class="kicker">Information</p>
          <ul class="mt-4 space-y-2">
            <li><a href="/privacy" class="text-stone-600 hover:text-maroon-700 hover:underline">Privacy Policy</a></li>
            <li><a href="/contact#grievance" class="text-stone-600 hover:text-maroon-700 hover:underline">Grievance & Anti-Ragging</a></li>
            <li><a href={site.admission.portal} rel="noopener" class="text-stone-600 hover:text-maroon-700 hover:underline">DVET Admission Portal ↗</a></li>
          </ul>
          <!-- Required whenever machine translation is offered. -->
          <p class="mt-6 border-l-2 border-stone-300 pl-3 text-xs leading-relaxed text-stone-500">
            Marathi translation on this site is automated. The English version is authoritative.
            For fees, dates and eligibility, please confirm with the office.
          </p>
        </div>
      </div>

      <div class="border-t border-stone-200 px-4 py-5 text-center text-xs text-stone-500">
        © {new Date().getFullYear()} {site.name}, Waghulgaon, Akola. Run by {site.runBy}.
      </div>
    </footer>

    <!-- Sticky Call + WhatsApp. Inbound calls convert ~10-15x better than forms
         for this audience; typing on a low-end Android is a real barrier. -->
    <div class="fixed inset-x-0 bottom-0 z-40 grid grid-cols-2 border-t border-maroon-900 md:hidden">
      <a href={`tel:${site.phonePrimary}`} class="flex min-h-[3.5rem] items-center justify-center gap-2 bg-maroon-700 text-base font-semibold text-white">
        <Icon name="phone" size={18} /> Call Now
      </a>
      <a href={`https://wa.me/91${site.whatsapp}`} rel="noopener" class="flex min-h-[3.5rem] items-center justify-center gap-2 bg-whatsapp text-base font-semibold text-white">
        <Icon name="whatsapp" size={18} /> WhatsApp
      </a>
    </div>
  </body>
</html>

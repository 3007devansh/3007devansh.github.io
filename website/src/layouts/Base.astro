---
import '../styles/global.css';
import Seo from '../components/Seo.astro';
import { site } from '../config/site';

interface Props {
  title: string;
  description: string;
  schema?: Record<string, unknown>[];
  ogImage?: string;
}
const { title, description, schema, ogImage } = Astro.props;

/** "Courses", never "Trades" — see content.config.ts */
const nav = [
  { href: '/', label: 'Home', mr: 'मुख्यपृष्ठ' },
  { href: '/courses', label: 'Courses', mr: 'अभ्यासक्रम' },
  { href: '/admissions', label: 'Admissions', mr: 'प्रवेश' },
  { href: '/about', label: 'About', mr: 'आमच्याविषयी' },
  { href: '/faq', label: 'FAQ', mr: 'प्रश्न' },
  { href: '/contact', label: 'Contact', mr: 'संपर्क' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Devanagari must not fall back to the device font; cheap Androids render it inconsistently.
         TODO: self-host these woff2 files to remove the third-party request. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+Devanagari:wght@400;600;700&display=swap"
    />

    <Seo title={title} description={description} schema={schema} ogImage={ogImage} />
  </head>

  <body class="bg-white font-sans text-slate-800 antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:rounded focus:bg-white focus:px-4 focus:py-2 focus:shadow-lg"
      >Skip to content</a
    >

    <!-- Utility strip: recognition + phone. Legitimacy first — this audience
         is verifying we are real before they read anything else. -->
    <div class="bg-maroon-900 text-white">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-1.5 text-xs">
        <p class="flex items-center gap-1.5">
          <span aria-hidden="true">🏛️</span>
          <span class="font-semibold">{site.approval}</span>
          <span class="hidden text-white/60 sm:inline">· Run by {site.runBy}</span>
        </p>
        <a href={`tel:${site.phonePrimary}`} class="font-semibold hover:underline">
          ☎ {site.phonePrimary}
        </a>
      </div>
    </div>

    <header class="sticky top-0 z-30 border-b border-slate-200 bg-white/95 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
        <a href="/" class="flex items-center gap-3">
          <span
            class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-maroon-700 text-lg font-black text-white"
            aria-hidden="true">D</span
          >
          <span class="flex flex-col leading-tight">
            <span class="text-lg font-extrabold tracking-tight text-maroon-800">{site.name}</span>
            <span class="text-xs text-slate-500">Akola, Maharashtra</span>
          </span>
        </a>

        <nav aria-label="Main" class="hidden items-center gap-0.5 lg:flex">
          {
            nav.map((i) => (
              <a
                href={i.href}
                aria-current={isActive(i.href) ? 'page' : undefined}
                class:list={[
                  'rounded-md px-3 py-2 text-sm font-semibold transition hover:bg-maroon-50 hover:text-maroon-700',
                  isActive(i.href) ? 'bg-maroon-50 text-maroon-700' : 'text-slate-600',
                ]}
              >
                {i.label}
              </a>
            ))
          }
        </nav>

        <div class="flex items-center gap-2">
          <!-- Language switcher: labelled in the native script, never a flag icon.
               (A flag maps to a country, not a language.) Marathi routes ship in phase 2. -->
          <span
            class="hidden rounded-md border border-slate-200 px-2.5 py-1.5 text-xs font-semibold text-slate-400 sm:inline"
            title="Marathi version coming soon">मराठी</span
          >
          <a
            href={`tel:${site.phonePrimary}`}
            class="hidden rounded-lg bg-maroon-700 px-4 py-2.5 text-sm font-bold text-white shadow-sm transition hover:bg-maroon-800 md:inline-block"
          >
            Call Now
          </a>
        </div>
      </div>

      <nav aria-label="Sections" class="flex overflow-x-auto border-t border-slate-100 px-2 lg:hidden">
        {
          nav.map((i) => (
            <a
              href={i.href}
              aria-current={isActive(i.href) ? 'page' : undefined}
              class:list={[
                'shrink-0 px-3 py-2.5 text-sm font-semibold whitespace-nowrap',
                isActive(i.href)
                  ? 'border-b-2 border-maroon-700 text-maroon-700'
                  : 'border-b-2 border-transparent text-slate-600',
              ]}
            >
              {i.label}
            </a>
          ))
        }
      </nav>
    </header>

    <main id="main"><slot /></main>

    <footer class="mt-20 border-t border-slate-200 bg-slate-50">
      <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:grid-cols-2 lg:grid-cols-4">
        <div class="sm:col-span-2 lg:col-span-1">
          <p class="text-lg font-extrabold text-maroon-800">{site.name}</p>
          <p class="mt-1 mr text-sm text-slate-600">{site.nameMr}</p>
          <p class="mt-3 text-sm text-slate-600">Run by {site.runBy}</p>
          <p class="mt-3 inline-block rounded-md bg-maroon-100 px-2.5 py-1 text-xs font-bold text-maroon-800">
            {site.approval}
          </p>
        </div>

        <div class="text-sm">
          <p class="font-bold text-slate-900">Contact</p>
          <address class="mt-3 space-y-1.5 not-italic text-slate-600">
            <p>{site.addressShort}</p>
            <p><a href={`tel:${site.phonePrimary}`} class="font-semibold text-maroon-700 hover:underline">{site.phonePrimary}</a></p>
            <p><a href={`tel:${site.phoneSecondary}`} class="font-semibold text-maroon-700 hover:underline">{site.phoneSecondary}</a></p>
          </address>
        </div>

        <div class="text-sm">
          <p class="font-bold text-slate-900">Pages</p>
          <ul class="mt-3 space-y-1.5">
            {nav.slice(1).map((i) => (
              <li><a href={i.href} class="text-slate-600 hover:text-maroon-700 hover:underline">{i.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="text-sm">
          <p class="font-bold text-slate-900">Information</p>
          <ul class="mt-3 space-y-1.5">
            <li><a href="/privacy" class="text-slate-600 hover:text-maroon-700 hover:underline">Privacy Policy</a></li>
            <li><a href="/contact#grievance" class="text-slate-600 hover:text-maroon-700 hover:underline">Grievance & Anti-Ragging</a></li>
            <li><a href={site.admission.portal} rel="noopener" class="text-slate-600 hover:text-maroon-700 hover:underline">DVET Admission Portal ↗</a></li>
          </ul>
        </div>
      </div>

      <div class="border-t border-slate-200 px-4 py-5 text-center text-xs text-slate-500">
        © {new Date().getFullYear()} {site.name}, Waghulgaon, Akola. Run by {site.runBy}.
      </div>
    </footer>

    <!--
      Sticky Call + WhatsApp bar.
      Research-backed: inbound calls convert ~10-15x better than form submissions,
      and typing on a low-end Android keyboard is a real barrier for this audience.
      These outrank the enquiry form, not the other way round.
    -->
    <div class="fixed inset-x-0 bottom-0 z-40 grid grid-cols-2 shadow-[0_-2px_12px_rgba(0,0,0,0.15)] md:hidden">
      <a
        href={`tel:${site.phonePrimary}`}
        class="flex min-h-[3.5rem] items-center justify-center gap-2 bg-maroon-700 text-base font-bold text-white"
      >
        <span aria-hidden="true">📞</span> Call Now
      </a>
      <a
        href={`https://wa.me/91${site.whatsapp}`}
        rel="noopener"
        class="flex min-h-[3.5rem] items-center justify-center gap-2 bg-[#25D366] text-base font-bold text-white"
      >
        <span aria-hidden="true">💬</span> WhatsApp
      </a>
    </div>
  </body>
</html>
